---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import siteProfile from '../../data/site-profile.json';
import { blogCategories } from '../../data/blog-categories';
import BlogPostCard from '../../components/blog/BlogPostCard.astro';
import BlogPagination from '../../components/blog/BlogPagination.astro';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const posts = await getCollection('blog', ({ data }: any) => !data.draft);
  const sorted = posts.sort(
    (a: any, b: any) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
  );
  return paginate(sorted, { pageSize: 9 });
}

const { page } = Astro.props as any;

const pageTitle = page.currentPage === 1
  ? 'Blog | Park 101 Carlsbad'
  : `Blog | Page ${page.currentPage} | Park 101 Carlsbad`;
const pageDescription =
  'Game day guides, food and drink features, and what\'s happening at Park 101 in Carlsbad Village — North County\'s rooftop sports bar and BBQ destination.';

const canonical = page.currentPage === 1
  ? `${siteProfile.url}/blog`
  : `${siteProfile.url}/blog/${page.currentPage}`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteProfile.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteProfile.url}/blog` },
  ],
};

const categoryList = Object.values(blogCategories);
---

<Layout title={pageTitle} description={pageDescription} canonical={canonical} ogImage={siteProfile.seo.ogImage} transparentNav={true}>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative bg-brand-dark pt-40 pb-16 px-6 sm:px-8 lg:px-12 overflow-hidden">
    <div class="max-w-7xl mx-auto text-center">
      <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-4">
        Park 101 Blog
      </span>
      <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-brand-white uppercase leading-display tracking-tight mb-4">
        Game Day, Food &amp; What's Happening
      </h1>
      <p class="font-body text-base sm:text-lg text-brand-white/70 max-w-2xl mx-auto">
        Guides to game day, the food and drink program, and life at Park 101 in Carlsbad Village.
      </p>
    </div>
  </section>

  <!-- ── CATEGORY FILTER ──────────────────────────────────── -->
  <section class="bg-brand-cream border-b border-brand-dark/10 px-6 sm:px-8 lg:px-12 py-6">
    <div class="max-w-7xl mx-auto flex flex-wrap gap-3">
      <a
        href="/blog"
        class="font-body text-xs font-bold uppercase tracking-label px-4 py-2 rounded-full bg-brand-orange text-brand-white"
      >
        All Posts
      </a>
      {categoryList.map((cat) => (
        <a
          href={`/blog/category/${cat.slug}`}
          class="font-body text-xs font-bold uppercase tracking-label px-4 py-2 rounded-full border border-brand-dark/20 hover:border-brand-orange hover:text-brand-orange transition-colors duration-150"
        >
          {cat.label}
        </a>
      ))}
    </div>
  </section>

  <!-- ── POST GRID ────────────────────────────────────────── -->
  <section class="bg-brand-cream px-6 sm:px-8 lg:px-12 py-16">
    <div class="max-w-7xl mx-auto">
      {page.data.length === 0 ? (
        <p class="font-body text-brand-dark/60 text-center py-20">
          New posts are on the way — check back soon.
        </p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {page.data.map((post: any) => (
            <BlogPostCard post={post} />
          ))}
        </div>
      )}

      <BlogPagination currentPage={page.currentPage} lastPage={page.lastPage} baseUrl="/blog" />
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
