---
import { getCollection } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import siteProfile from '../../../../data/site-profile.json';
import { blogCategories, getCategoryMeta } from '../../../../data/blog-categories';
import BlogPostCard from '../../../../components/blog/BlogPostCard.astro';
import BlogPagination from '../../../../components/blog/BlogPagination.astro';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const posts = await getCollection('blog', ({ data }: any) => !data.draft);

  return Object.keys(blogCategories).flatMap((categorySlug) => {
    const filtered = posts
      .filter((post: any) => post.data.category === categorySlug)
      .sort((a: any, b: any) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

    return paginate(filtered, {
      params: { category: categorySlug },
      pageSize: 9,
    });
  });
}

const { category } = Astro.params;
const { page } = Astro.props as any;
const categoryMeta = getCategoryMeta(category as string);

const pageTitle = page.currentPage === 1
  ? `${categoryMeta.label} | Park 101 Blog`
  : `${categoryMeta.label} | Page ${page.currentPage} | Park 101 Blog`;
const pageDescription = categoryMeta.description || `${categoryMeta.label} posts from Park 101 in Carlsbad Village.`;

const canonical = page.currentPage === 1
  ? `${siteProfile.url}/blog/category/${categoryMeta.slug}/`
  : `${siteProfile.url}/blog/category/${categoryMeta.slug}/${page.currentPage}/`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteProfile.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteProfile.url}/blog` },
    { '@type': 'ListItem', position: 3, name: categoryMeta.label, item: `${siteProfile.url}/blog/category/${categoryMeta.slug}` },
  ],
};
---

<Layout title={pageTitle} description={pageDescription} canonical={canonical} ogImage={categoryMeta.image} transparentNav={true}>

  <!-- ── BREADCRUMB ───────────────────────────────────────── -->
  <nav aria-label="Breadcrumb" class="bg-brand-dark pt-28 pb-4 px-6 sm:px-8 lg:px-12">
    <ol class="max-w-7xl mx-auto flex items-center gap-2 font-body text-xs text-brand-white/60">
      <li><a href="/" class="hover:text-brand-orange transition-colors duration-150">Home</a></li>
      <li>/</li>
      <li><a href="/blog" class="hover:text-brand-orange transition-colors duration-150">Blog</a></li>
      <li>/</li>
      <li class="text-brand-white font-medium">{categoryMeta.label}</li>
    </ol>
  </nav>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative bg-brand-dark pb-16 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto text-center">
      <h1 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-4">
        {categoryMeta.label}
      </h1>
      <p class="font-body text-base sm:text-lg text-brand-white/70 max-w-2xl mx-auto">
        {categoryMeta.description}
      </p>
    </div>
  </section>

  <!-- ── POST GRID ────────────────────────────────────────── -->
  <section class="bg-brand-cream px-6 sm:px-8 lg:px-12 py-16">
    <div class="max-w-7xl mx-auto">
      {page.data.length === 0 ? (
        <p class="font-body text-brand-dark/60 text-center py-20">
          No {categoryMeta.label.toLowerCase()} posts yet — check back soon.
        </p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {page.data.map((post: any) => (
            <BlogPostCard post={post} />
          ))}
        </div>
      )}

      <BlogPagination currentPage={page.currentPage} lastPage={page.lastPage} baseUrl={`/blog/category/${categoryMeta.slug}`} />
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
