---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import StatBar from '../components/core/StatBar.astro';
import SplitIntro from '../components/core/SplitIntro.astro';
import { Image } from 'astro:assets';
import brunchChilaquilesImg from '../assets/brunch/park-101-brunch-chilaquiles-tri-tip-carlsbad.jpg';
import brunchBurrito02 from '../assets/brunch/park-101-brunch-brisket-burrito-02-carlsbad.jpg';
import rooftopDiningImg from '../assets/venue/park-101-rooftop-dining-carlsbad-village-carlsbad.jpg';

const siteProfile = (await getEntry('siteSettings', 'site-settings'))!.data;
const page = (await getCollection('brunchPage'))[0].data;
const assetImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpg,jpeg,png,webp}', { eager: true });
const allMenuItems = (await getCollection('menuItems')).sort((a, b) => a.data.order - b.data.order);
const toGridItem = ({ data }: (typeof allMenuItems)[number]) => ({
  ...data,
  src: assetImages[data.image].default,
  alt: data.imageAlt,
});
const foodItems = allMenuItems
  .filter(({ data }) => data.menu === 'brunch' && data.section === 'food')
  .map(toGridItem);
const drinkItems = allMenuItems
  .filter(({ data }) => data.menu === 'brunch' && data.section === 'drink')
  .map(toGridItem);

const faqs = [
  {
    q: 'What time does brunch start at Park 101?',
    a: 'Brunch is served daily starting at 11:00 AM on the rooftop, until 2:00 PM.',
  },
  {
    q: 'Do I need a reservation for brunch?',
    a: 'Reservations are recommended for brunch, especially for larger groups, since the rooftop fills up quickly.',
  },
  {
    q: "What's on the brunch menu?",
    a: 'A BBQ-driven brunch program — smoked tri-tip chilaquiles, brisket and classic breakfast burritos, a chicken and waffle sandwich, and bacon, egg and cheese plates.',
  },
  {
    q: 'Are brunch cocktails available?',
    a: 'Yes — the Rodeo Tower, the Coschie Boot, and the full cocktail program are all available starting at open.',
  },
  {
    q: 'Can I book a private brunch event?',
    a: 'Yes. Park 101 hosts private brunch gatherings, birthday brunches, and group events on the rooftop and throughout the venue.',
  },
  {
    q: 'Is Park 101 dog-friendly for brunch?',
    a: "Yes — the patio is dog-friendly, and brunch is built for groups of all ages.",
  },
];

const pageTitle = page.seo.title;
const pageDescription = page.seo.description;
const blockText = (value: string) => `\n${value}\n`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} ogImage={page.seo.ogImage} transparentNav={true}>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-[650px] bg-brand-dark flex flex-col overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={brunchChilaquilesImg}
        alt="Smoked tri-tip chilaquiles brunch plate at Park 101 Carlsbad"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
        width={1920}
      />
      <div class="absolute inset-0 bg-brand-dark/70"></div>
    </div>
    <div class="h-20 shrink-0"></div>
    <div class="relative z-10 flex-1 flex items-center justify-center px-6 sm:px-8 lg:px-12 pb-16">
    <div class="max-w-3xl mx-auto text-center">
      <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4"><Fragment set:html={blockText(page.hero.eyebrow)} /></span>
      <h1 class="font-display font-bold text-section-xl text-brand-white uppercase leading-ultra tracking-tight mb-6">{blockText(page.hero.heading)}</h1>
      <p class="font-body font-light text-brand-cream/80 text-lg leading-relaxed mb-8 max-w-xl mx-auto">{blockText(page.hero.body!)}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={siteProfile.ordering.reservationsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
        >
          Reserve for Brunch
        </a>
        <a
          href="/menu"
          class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
        >
          View Brunch Menu
        </a>
      </div>
    </div>
    </div>
  </section>

  <!-- ── STAT BAR ─────────────────────────────────────────── -->
  <StatBar stats={[
    { value: '11 AM', label: 'Start Time' },
    { value: 'Daily', label: 'Days Available' },
    { value: 'Rooftop', label: 'Open-Air' },
    { value: 'Dog-Friendly', label: 'Patio' },
  ]} />

  <!-- ── NOT JUST BRUNCH ──────────────────────────────────── -->
  <SplitIntro
    image={brunchBurrito02}
    imageAlt="Brisket breakfast burrito with fries at Park 101 Carlsbad brunch"
    eyebrow={page.intro!.eyebrow}
    heading={page.intro!.heading}
    body={page.intro!.body!}
    ctaLabel="Reserve a Table"
    ctaHref={siteProfile.ordering.reservationsUrl}
    ctaExternal={true}
  />

  <!-- ── FOOD GRID ─────────────────────────────────────────── -->
  <section class="relative bg-brand-dark py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-14">
        <span class="block font-body text-xs font-bold tracking-eyebrow-wide uppercase text-brand-orange mb-3">{blockText(page.sections.food.eyebrow)}</span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight">{blockText(page.sections.food.heading)}</h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5">
        {foodItems.map((item) => (
          <div class="group relative overflow-hidden bg-brand-dark-light aspect-[4/3]">
            <Image
              src={item.src}
              alt={item.alt}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
              loading="lazy"
              width={800}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-5">
              <span class="font-display font-bold text-base uppercase tracking-wider text-brand-white">{item.name}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href="/menu"
          class="inline-block px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200"
        >
          Full Brunch Menu
        </a>
      </div>
    </div>
  </section>

  <!-- ── BRUNCH COCKTAILS ─────────────────────────────────── -->
  <section class="relative bg-brand-steel py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-5xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-12">
        <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(page.sections.drink.eyebrow)}</span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight">{blockText(page.sections.drink.heading)}</h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {drinkItems.map((item) => (
          <div class="relative overflow-hidden bg-brand-dark aspect-square">
            <Image
              src={item.src}
              alt={item.alt}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
              width={800}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/85 via-transparent to-transparent flex items-end p-4">
              <span class="font-display font-bold text-sm uppercase tracking-wide text-brand-white">{item.name}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PRIVATE BRUNCH CROSS-LINK ─────────────────────────── -->
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[500px]">
      <div class="lg:col-span-6 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-20 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(page.sections.privateEvents.eyebrow)}</span>
          <h2 class="font-display font-bold text-3xl sm:text-4xl text-brand-dark uppercase leading-display tracking-tight mb-6">{blockText(page.sections.privateEvents.heading)}</h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base leading-relaxed mb-8">{blockText(page.sections.privateEvents.body!)}</p>
          <a
            href="/private-events"
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            Inquire About Your Event
          </a>
        </div>
      </div>
      <div class="relative lg:col-span-6 min-h-[350px] lg:min-h-full overflow-hidden">
        <Image
          src={rooftopDiningImg}
          alt="Rooftop dining at Park 101 Carlsbad, ideal for private brunch events"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
          width={1400}
        />
      </div>
    </div>
  </section>

  <!-- ── FAQ ───────────────────────────────────────────────── -->
  <section class="relative bg-brand-dark py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-14">
        <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(page.sections.faq.eyebrow)}</span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight">{blockText(page.sections.faq.heading)}</h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="space-y-6">
        {faqs.map((item) => (
          <div class="border-b border-brand-white/15 pb-6">
            <h3 class="font-display font-bold text-base uppercase tracking-tight text-brand-white mb-2">{item.q}</h3>
            <p class="font-body font-light text-brand-cream/70 text-sm leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────────── -->
  <section class="relative bg-brand-tan py-20 px-6 sm:px-8 lg:px-12 text-center">
    <div class="max-w-2xl mx-auto">
      <span class="block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-dark/70 mb-4">{blockText(page.sections.final.eyebrow)}</span>
      <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">{blockText(page.sections.final.heading)}</h2>
      <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">{blockText(page.sections.final.body!)}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={siteProfile.ordering.reservationsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
        >
          Reserve for Brunch
        </a>
        <a
          href="/menu"
          class="px-8 py-4 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
        >
          View Brunch Menu
        </a>
      </div>
    </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

</Layout>
