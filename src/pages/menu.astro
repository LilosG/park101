---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import MenuItemCard from '../components/menu/MenuItemCard.astro';
import StatBar from '../components/core/StatBar.astro';
import SplitIntro from '../components/core/SplitIntro.astro';
import { Image } from 'astro:assets';

import foodSpreadImg from '../assets/food/park-101-prk-food-spread-carlsbad.jpg';
import foodSpreadIntroImg from '../assets/food/park-101-food-spread-intro-carlsbad.jpg';

const siteProfile = (await getEntry('siteSettings', 'site-settings'))!.data;
const page = (await getCollection('menuPage'))[0].data;
const assetImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpg,jpeg,png,webp}', { eager: true });
const dinnerFoodItems = (await getCollection('dinnerFoodItems')).sort((a, b) => a.data.order - b.data.order);
const dinnerDrinkItems = (await getCollection('dinnerDrinkItems')).sort((a, b) => a.data.order - b.data.order);
const toCardItem = ({ data }: (typeof dinnerFoodItems)[number] | (typeof dinnerDrinkItems)[number]) => ({
  ...data,
  src: assetImages[data.image].default,
  alt: data.imageAlt,
});
const menuItems = dinnerFoodItems.map(toCardItem);
const cocktailItems = dinnerDrinkItems.map(toCardItem);

const pageTitle = page.seo.title;
const pageDescription = page.seo.description;
const blockText = (value: string) => `\n${value}\n`;
const foodSection = page.sections.food;
const drinkSection = page.sections.drink;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteProfile.url },
    { '@type': 'ListItem', position: 2, name: 'Menu', item: `${siteProfile.url}/menu` },
  ],
};
---

<Layout title={pageTitle} description={pageDescription} ogImage={page.seo.ogImage} transparentNav={true}>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-[550px] bg-brand-dark flex flex-col overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={foodSpreadImg}
        alt="A spread of BBQ dishes at Park 101 Carlsbad"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
        width={1920}
      />
      <div class="absolute inset-0 bg-brand-dark/60"></div>
    </div>
    <div class="h-20 shrink-0"></div>
    <div class="relative z-10 flex-1 flex items-center justify-center px-6 sm:px-8 lg:px-12 pb-16">
      <div class="max-w-2xl mx-auto text-center">
        <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">{blockText(page.hero.eyebrow)}</span>
        <h1 class="font-display font-bold text-hero text-brand-white uppercase leading-ultra tracking-tight mb-6">{blockText(page.hero.heading)}</h1>
        {page.hero.body && (
          <p class="font-body font-light text-brand-cream/80 text-lg leading-relaxed max-w-lg mx-auto">{blockText(page.hero.body)}</p>
        )}
      </div>
    </div>
  </section>

  <!-- ── STAT BAR ─────────────────────────────────────────── -->
  <StatBar stats={[
    { value: 'Wood-Smoked', label: 'BBQ' },
    { value: 'Rooftop', label: 'Open-Air' },
    { value: 'Dog-Friendly', label: 'Patio' },
    { value: 'One Block', label: 'From The Beach' },
  ]} />

  <!-- ── INTRO ────────────────────────────────────────────── -->
  {page.intro && (
    <SplitIntro
      image={foodSpreadIntroImg}
      imageAlt="A spread of wood-smoked BBQ dishes at Park 101 Carlsbad"
      eyebrow={page.intro.eyebrow}
      heading={page.intro.heading}
      body={page.intro.body}
      ctaLabel="Order Online"
      ctaHref={siteProfile.ordering.toastUrl}
      ctaExternal={true}
    />
  )}

  <!-- ── MENU GRID ────────────────────────────────────────── -->
  {foodSection && (
  <section class="relative bg-brand-steel py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-14">
        <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(foodSection.eyebrow)}</span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight">{blockText(foodSection.heading)}</h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {menuItems.map((item) => (
          <MenuItemCard src={item.src} alt={item.alt} name={item.name} description={item.description} />
        ))}
      </div>

      <div class="text-center mt-14">
        <a
          href={siteProfile.ordering.toastUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200"
        >
          Order Online
        </a>
      </div>
    </div>
  </section>
  )}

  <!-- ── COCKTAILS ────────────────────────────────────────── -->
  {drinkSection && (
  <section class="relative bg-brand-dark py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-14">
        <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(drinkSection.eyebrow)}</span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight">{blockText(drinkSection.heading)}</h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {cocktailItems.map((item) => (
          <MenuItemCard src={item.src} alt={item.alt} name={item.name} description={item.description} />
        ))}
      </div>
    </div>
  </section>
  )}

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
