---
import Layout from '../layouts/Layout.astro';
import siteProfile from '../data/site-profile.json';
import StatBar from '../components/core/StatBar.astro';

const venue = siteProfile.venue;

const pageTitle = 'The Venue | Rooftop, Courtyard & Indoor Bar in Carlsbad | PRK 101';
const pageDescription =
  "Explore Park 101's multi-level venue in Carlsbad Village — rooftop deck, open-air courtyard with LED wall, indoor bar, and family and dog-friendly spaces throughout.";
---

<Layout title={pageTitle} description={pageDescription} ogImage={siteProfile.seo.ogImage} transparentNav={true}>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-[650px] bg-brand-dark flex flex-col overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/venue/park-101-outdoor-waterfront-rooftop-bar-carlsbad.jpg"
        alt="Rooftop deck at Park 101 Carlsbad with Carlsbad Village skyline"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-brand-dark/65"></div>
    </div>
    <div class="h-20 shrink-0"></div>
    <div class="relative z-10 flex-1 flex items-center justify-center px-6 sm:px-8 lg:px-12 pb-16">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">
          {siteProfile.contact.neighborhood}
        </span>
        <h1 class="font-display font-bold text-section-xl text-brand-white uppercase leading-ultra tracking-tight mb-6">
          Rooftop. Courtyard.<br />Indoor Bar.
        </h1>
        <p class="font-body font-light text-brand-cream/80 text-lg leading-relaxed mb-8 max-w-xl mx-auto">
          Three distinct spaces under one open sky. The central courtyard with the massive LED wall, the elevated rooftop deck, and the indoor bar with wall-to-wall screens — one block from the beach.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={siteProfile.ordering.reservationsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
          >
            Reserve a Table
          </a>
          <a
            href="/private-events"
            class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
          >
            Private Events
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── STAT BAR ─────────────────────────────────────────── -->
  <StatBar stats={[
    { value: '2', label: 'Levels' },
    { value: '20+', label: 'Screens' },
    { value: 'Multiple', label: 'Bars' },
    { value: 'Dog-Friendly', label: 'Patio' },
  ]} />

  <!-- ── THE ROOFTOP ──────────────────────────────────────── -->
  <section class="relative bg-brand-dark">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="relative lg:col-span-7 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/venue/park-101-outdoor-rooftop-bar-evening-crowd-carlsbad.jpg"
          alt="Rooftop deck at Park 101 Carlsbad at dusk"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
      <div class="lg:col-span-5 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-dark">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            Upstairs
          </span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6">
            {venue.rooftop.headline}
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-cream/70 text-base sm:text-lg leading-relaxed mb-8">
            {venue.rooftop.description}
          </p>
          <div class="flex flex-wrap gap-x-4 gap-y-2">
            {venue.rooftop.features.map((feature) => (
              <span class="font-display font-bold text-xs uppercase tracking-feature text-brand-white">{feature}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── THE COURTYARD ────────────────────────────────────── -->
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="lg:col-span-5 order-2 lg:order-1 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            Ground Level
          </span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">
            {venue.courtyard.headline}
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">
            {venue.courtyard.description}
          </p>
          <div class="flex flex-wrap gap-x-4 gap-y-2">
            {venue.courtyard.features.map((feature) => (
              <span class="font-display font-bold text-xs uppercase tracking-feature text-brand-dark">{feature}</span>
            ))}
          </div>
        </div>
      </div>
      <div class="relative lg:col-span-7 order-1 lg:order-2 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/venue/park-101-outdoor-fire-pit-patio-venue-carlsbad.jpg"
          alt="Open-air courtyard with fire pit and LED wall at Park 101 Carlsbad"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ── GAME DAY & BIG SCREENS ────────────────────────────── -->
  <section class="relative bg-brand-dark">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="relative lg:col-span-7 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/venue/park-101-padres-game-day-packed-venue-carlsbad.jpg"
          alt="Packed crowd watching sports on the big screens at Park 101 Carlsbad"
          class="absolute inset-0 w-full h-full object-cover object-[50%_35%]"
          loading="lazy"
        />
      </div>
      <div class="lg:col-span-5 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-dark">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            Every Kickoff, Every Fight
          </span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6">
            {venue.sports.headline}
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-cream/70 text-base sm:text-lg leading-relaxed mb-8">
            {venue.sports.description}
          </p>
          <div class="flex flex-wrap gap-x-4 gap-y-2">
            {venue.sports.features.map((feature) => (
              <span class="font-display font-bold text-xs uppercase tracking-feature text-brand-white">{feature}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── INDOOR BAR & DINING ROOM ──────────────────────────── -->
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="lg:col-span-5 order-2 lg:order-1 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            Indoors
          </span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">
            {venue.indoorBar.headline}
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">
            {venue.indoorBar.description}
          </p>
          <div class="flex flex-wrap gap-x-4 gap-y-2 mb-8">
            {venue.indoorBar.features.map((feature) => (
              <span class="font-display font-bold text-xs uppercase tracking-feature text-brand-dark">{feature}</span>
            ))}
          </div>
          <a
            href="/menu"
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            View the Menu
          </a>
        </div>
      </div>
      <div class="relative lg:col-span-7 order-1 lg:order-2 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/venue/park-101-modern-sports-bar-wood-interior-carlsbad.jpg"
          alt="Indoor bar and dining room at Park 101 Carlsbad"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ── FAMILY, KIDS & DOGS ───────────────────────────────── -->
  <section class="relative bg-brand-tan">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="relative lg:col-span-6 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/venue/park-101-families-kids-game-day-carlsbad.jpg"
          alt="Families and kids enjoying game day together at Park 101 Carlsbad"
          class="absolute inset-0 w-full h-full object-cover object-[50%_75%]"
          loading="lazy"
        />
      </div>
      <div class="lg:col-span-6 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-tan">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            {venue.familiesPets.headline}
          </span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">
            Bring the Crew.<br />Bring the Dog.
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">
            {venue.familiesPets.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {venue.familiesPets.features.map((feature) => (
              <span class="px-3 py-1.5 border border-brand-dark/25 font-display font-bold text-xs uppercase tracking-wide text-brand-dark">{feature}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────────── -->
  <section class="relative bg-brand-dark py-20 px-6 sm:px-8 lg:px-12 text-center">
    <div class="max-w-2xl mx-auto">
      <span class="block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">
        Come See It
      </span>
      <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6">
        Park 101 Awaits.
      </h2>
      <p class="font-body font-light text-brand-cream/80 text-base sm:text-lg leading-relaxed mb-8">
        One block from the beach in Carlsbad Village. Open daily.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={siteProfile.ordering.reservationsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
        >
          Reserve a Table
        </a>
        <a
          href="/private-events"
          class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
        >
          Plan a Private Event
        </a>
      </div>
    </div>
  </section>

</Layout>
