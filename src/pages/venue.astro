---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import StatBar from '../components/core/StatBar.astro';
import { Image } from 'astro:assets';
import waterfrontRooftop from '../assets/venue/park-101-outdoor-waterfront-rooftop-bar-carlsbad.jpg';
import eveningCrowd from '../assets/venue/park-101-outdoor-rooftop-bar-evening-crowd-carlsbad.jpg';
import firePitPatioVenue from '../assets/venue/park-101-outdoor-fire-pit-patio-venue-carlsbad.jpg';
import padresGameDayVenue from '../assets/venue/park-101-padres-game-day-packed-venue-carlsbad.jpg';
import sportsBarInterior from '../assets/venue/park-101-modern-sports-bar-wood-interior-carlsbad.jpg';
import familiesKidsVenue from '../assets/venue/park-101-families-kids-game-day-carlsbad.jpg';

const siteProfile = (await getEntry('siteSettings', 'site-settings'))!.data;
const page = (await getCollection('venuePage'))[0].data;
const venue = siteProfile.venue;

const pageTitle = page.seo.title;
const pageDescription = page.seo.description;
const blockText = (value: string) => `\n${value}\n`;
const blockHtml = (value: string) => `\n${value.replaceAll('<br />', '<br>')}\n`;
const inlineText = (value: string) => ` ${value} `;
---

<Layout title={pageTitle} description={pageDescription} ogImage={page.seo.ogImage} transparentNav={true}>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-[650px] bg-brand-dark flex flex-col overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={waterfrontRooftop}
        alt="Rooftop deck at Park 101 Carlsbad with Carlsbad Village skyline"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
        width={1920}
      />
      <div class="absolute inset-0 bg-brand-dark/65"></div>
    </div>
    <div class="h-20 shrink-0"></div>
    <div class="relative z-10 flex-1 flex items-center justify-center px-6 sm:px-8 lg:px-12 pb-16">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">{inlineText(page.hero.eyebrow)}</span>
        <h1 class="font-display font-bold text-section-xl text-brand-white uppercase leading-ultra tracking-tight mb-6"><Fragment set:html={blockHtml(page.hero.heading)} /></h1>
        <p class="font-body font-light text-brand-cream/80 text-lg leading-relaxed mb-8 max-w-xl mx-auto">{blockText(page.hero.body!)}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={siteProfile.ordering.reservationsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
          >
            Reserve a Table
          </a>
          <a
            href="/private-events"
            class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
          >
            Private Events
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── STAT BAR ─────────────────────────────────────────── -->
  <StatBar stats={[
    { value: '2', label: 'Levels' },
    { value: '20+', label: 'Screens' },
    { value: 'Multiple', label: 'Bars' },
    { value: 'Dog-Friendly', label: 'Patio' },
  ]} />

  <!-- ── THE ROOFTOP ──────────────────────────────────────── -->
  <section class="relative bg-brand-dark">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="relative lg:col-span-7 min-h-[400px] lg:min-h-full overflow-hidden">
        <Image
          src={eveningCrowd}
          alt="Rooftop deck at Park 101 Carlsbad at dusk"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
          width={1400}
        />
      </div>
      <div class="lg:col-span-5 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-dark">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(page.sections.rooftop.eyebrow)}</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6">{inlineText(page.sections.rooftop.heading)}</h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-cream/70 text-base sm:text-lg leading-relaxed mb-8">
            {venue.rooftop.description}
          </p>
          <div class="flex flex-wrap gap-x-4 gap-y-2">
            {venue.rooftop.features.map((feature: string) => (
              <span class="font-display font-bold text-xs uppercase tracking-feature text-brand-white">{feature}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── THE COURTYARD ────────────────────────────────────── -->
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="lg:col-span-5 order-2 lg:order-1 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(page.sections.courtyard.eyebrow)}</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">{inlineText(page.sections.courtyard.heading)}</h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">
            {venue.courtyard.description}
          </p>
          <div class="flex flex-wrap gap-x-4 gap-y-2">
            {venue.courtyard.features.map((feature: string) => (
              <span class="font-display font-bold text-xs uppercase tracking-feature text-brand-dark">{feature}</span>
            ))}
          </div>
        </div>
      </div>
      <div class="relative lg:col-span-7 order-1 lg:order-2 min-h-[400px] lg:min-h-full overflow-hidden">
        <Image
          src={firePitPatioVenue}
          alt="Open-air courtyard with fire pit and LED wall at Park 101 Carlsbad"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
          width={1400}
        />
      </div>
    </div>
  </section>

  <!-- ── GAME DAY & BIG SCREENS ────────────────────────────── -->
  <section class="relative bg-brand-dark">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="relative lg:col-span-7 min-h-[400px] lg:min-h-full overflow-hidden">
        <Image
          src={padresGameDayVenue}
          alt="Packed crowd watching sports on the big screens at Park 101 Carlsbad"
          class="absolute inset-0 w-full h-full object-cover object-[50%_35%]"
          loading="lazy"
          width={1400}
        />
      </div>
      <div class="lg:col-span-5 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-dark">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(page.sections.sports.eyebrow)}</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6">{inlineText(page.sections.sports.heading)}</h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-cream/70 text-base sm:text-lg leading-relaxed mb-8">
            {venue.sports.description}
          </p>
          <div class="flex flex-wrap gap-x-4 gap-y-2">
            {venue.sports.features.map((feature: string) => (
              <span class="font-display font-bold text-xs uppercase tracking-feature text-brand-white">{feature}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── INDOOR BAR & DINING ROOM ──────────────────────────── -->
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="lg:col-span-5 order-2 lg:order-1 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(page.sections.indoor.eyebrow)}</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">{inlineText(page.sections.indoor.heading)}</h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">
            {venue.indoorBar.description}
          </p>
          <div class="flex flex-wrap gap-x-4 gap-y-2 mb-8">
            {venue.indoorBar.features.map((feature: string) => (
              <span class="font-display font-bold text-xs uppercase tracking-feature text-brand-dark">{feature}</span>
            ))}
          </div>
          <a
            href="/menu"
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            View the Menu
          </a>
        </div>
      </div>
      <div class="relative lg:col-span-7 order-1 lg:order-2 min-h-[400px] lg:min-h-full overflow-hidden">
        <Image
          src={sportsBarInterior}
          alt="Indoor bar and dining room at Park 101 Carlsbad"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
          width={1400}
        />
      </div>
    </div>
  </section>

  <!-- ── FAMILY, KIDS & DOGS ───────────────────────────────── -->
  <section class="relative bg-brand-tan">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="relative lg:col-span-6 min-h-[400px] lg:min-h-full overflow-hidden">
        <Image
          src={familiesKidsVenue}
          alt="Families and kids enjoying game day together at Park 101 Carlsbad"
          class="absolute inset-0 w-full h-full object-cover object-[50%_75%]"
          loading="lazy"
          width={1400}
        />
      </div>
      <div class="lg:col-span-6 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-tan">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{inlineText(page.sections.families.eyebrow)}</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6"><Fragment set:html={blockHtml(page.sections.families.heading)} /></h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">
            {venue.familiesPets.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {venue.familiesPets.features.map((feature: string) => (
              <span class="px-3 py-1.5 border border-brand-dark/25 font-display font-bold text-xs uppercase tracking-wide text-brand-dark">{feature}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────────── -->
  <section class="relative bg-brand-dark py-20 px-6 sm:px-8 lg:px-12 text-center">
    <div class="max-w-2xl mx-auto">
      <span class="block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">{blockText(page.sections.final.eyebrow)}</span>
      <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6">{blockText(page.sections.final.heading)}</h2>
      <p class="font-body font-light text-brand-cream/80 text-base sm:text-lg leading-relaxed mb-8">{blockText(page.sections.final.body!)}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={siteProfile.ordering.reservationsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
        >
          Reserve a Table
        </a>
        <a
          href="/private-events"
          class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
        >
          Plan a Private Event
        </a>
      </div>
    </div>
  </section>

</Layout>
