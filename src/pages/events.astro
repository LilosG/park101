---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import EventInquiryForm from '../components/core/EventInquiryForm.astro';
import EventMatchupCard from '../components/events/EventMatchupCard.astro';
import { Image } from 'astro:assets';

import padresGameDayEvents from '../assets/venue/park-101-padres-game-day-packed-venue-carlsbad.jpg';

const siteProfile = (await getEntry('siteSettings', 'site-settings'))!.data;
const page = (await getCollection('eventsPage'))[0].data;
const eventTypeOrder = ['nfl-sundays', 'mlb-games', 'ufc-fight-nights', 'fantasy-draft-events', 'live-music', 'themed-nights'];
const eventTypes = (await getCollection('eventTypes'))
  .sort((a, b) => eventTypeOrder.indexOf(a.data.slug) - eventTypeOrder.indexOf(b.data.slug));
const upcomingEventOrder = [
  'world-cup-quarterfinals-norway-england',
  'world-cup-quarterfinals-argentina-switzerland',
];
const upcomingEvents = (await getCollection('upcomingEvents'))
  .sort((a, b) => upcomingEventOrder.indexOf(a.id) - upcomingEventOrder.indexOf(b.id));
const assetImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/**/*.{jpg,jpeg,png,webp}', { eager: true });

const pageTitle = page.seo.title;
const pageDescription = page.seo.description;
const blockText = (value: string) => `\n${value}\n`;
const blockHtml = (value: string) => `\n${value.replaceAll('<br />', '<br>')}\n`;
const inlineText = (value: string) => ` ${value} `;
const eventTypesSection = page.sections.eventTypes;
const upcomingSection = page.sections.upcoming;
const inquirySection = page.sections.inquiry;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteProfile.url },
    { '@type': 'ListItem', position: 2, name: 'Events', item: `${siteProfile.url}/events` },
  ],
};
---

<Layout title={pageTitle} description={pageDescription} ogImage={page.seo.ogImage} transparentNav={true}>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-[550px] bg-brand-dark flex flex-col overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={padresGameDayEvents}
        alt="Packed crowd at Park 101 Carlsbad during a game day event"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
        width={1920}
      />
      <div class="absolute inset-0 bg-brand-dark/65"></div>
    </div>
    <div class="h-20 shrink-0"></div>
    <div class="relative z-10 flex-1 flex items-center justify-center px-6 sm:px-8 lg:px-12 pb-16">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-block font-body text-xs font-bold tracking-eyebrow uppercase text-brand-orange mb-4">{inlineText(page.hero.eyebrow)}</span>
        <h1 class="font-display font-bold text-section-xl text-brand-white uppercase leading-ultra tracking-tight mb-6"><Fragment set:html={blockHtml(page.hero.heading)} /></h1>
        {page.hero.body && (
          <p class="font-body font-light text-brand-cream/80 text-lg leading-relaxed mb-8 max-w-xl mx-auto"><Fragment set:html={blockText(page.hero.body)} /></p>
        )}
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={siteProfile.ordering.reservationsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
          >
            Reserve a Table
          </a>
          <a
            href="/private-events/game-day-parties"
            class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
          >
            Book a Watch Party
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WHAT'S ALWAYS ON ─────────────────────────────────── -->
  {eventTypesSection && (
  <section class="bg-brand-cream px-6 sm:px-8 lg:px-12 py-20">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(eventTypesSection.eyebrow)}</span>
        <h2 class="font-display font-bold text-section text-brand-steel uppercase leading-display tracking-tight"><Fragment set:html={blockText(eventTypesSection.heading)} /></h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {eventTypes.map(({ data: type }) => {
          const image = assetImages[type.image]?.default;
          return (
            <div class="group relative aspect-[4/3] rounded-lg overflow-hidden">
              {image && (
                <Image
                  src={image}
                  alt={type.imageAlt}
                  class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-105"
                  loading="lazy"
                  width={800}
                />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/20 to-transparent"></div>
              <div class="absolute inset-x-0 bottom-0 p-6">
                <h3 class="font-display font-bold text-xl text-brand-white uppercase tracking-tight mb-1">
                  {type.name}
                </h3>
                <p class="font-body text-sm text-brand-white/80 leading-snug">
                  {type.description}
                </p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>
  )}

  <!-- ── UPCOMING EVENTS ──────────────────────────────────── -->
  {upcomingSection && (
  <section class="bg-brand-dark px-6 sm:px-8 lg:px-12 py-20">
    <div class="max-w-4xl mx-auto text-center">
      <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(upcomingSection.eyebrow)}</span>
      <h2 class="font-display font-bold text-section text-brand-white uppercase leading-display tracking-tight mb-8">{blockText(upcomingSection.heading)}</h2>
      {upcomingEvents.length === 0 ? (
        <p class="font-body text-brand-white/60 text-base max-w-lg mx-auto">
          Specific dates for upcoming games, fight nights, and live music are added here as they're scheduled.
          Follow along on
          {' '}<a href={siteProfile.social.instagram} target="_blank" rel="noopener noreferrer" class="text-brand-orange hover:text-brand-orange-light underline">Instagram</a>
          {' '}for the latest.
        </p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-left">
          {upcomingEvents.map(({ data: event }) => (
            <EventMatchupCard
              category={event.category}
              sideA={event.sideA}
              sideB={event.sideB}
              date={event.date}
              time={event.time}
              image={event.image}
              imageAlt={event.imageAlt}
            />
          ))}
        </div>
      )}
    </div>
  </section>
  )}

  <!-- ── CTA / INQUIRY FORM ───────────────────────────────── -->
  {inquirySection && (
    <EventInquiryForm
      eyebrow={inquirySection.eyebrow}
      heading={inquirySection.heading}
      subtext={inquirySection.body}
    />
  )}

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
