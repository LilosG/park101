---
import Layout from '../layouts/Layout.astro';
import siteProfile from '../data/site-profile.json';

const foodItems = [
  {
    src: '/images/food/park-101-tri-tip-tacos-07-carlsbad.jpg',
    alt: 'St. Louis ribs with BBQ sauce and pickles at Park 101 Carlsbad',
    name: 'St. Louis Ribs',
  },
  {
    src: '/images/food/park-101-the-chick-02-carlsbad.jpg',
    alt: 'Sliced smoked brisket platter with sauce at Park 101 Carlsbad',
    name: 'Smoked Brisket',
  },
  {
    src: '/images/food/park-101-surf-n-turf-fries-08-carlsbad.jpg',
    alt: 'Shrimp tacos with chipotle sauce and lime at Park 101 Carlsbad',
    name: 'Shrimp Tacos',
  },
  {
    src: '/images/food/park-101-smoked-wings-carlsbad.jpg',
    alt: 'Loaded bacon cheeseburger with fries at Park 101 Carlsbad',
    name: 'The Western Burger',
  },
  {
    src: '/images/food/park-101-tri-tip-x-arugula-08-carlsbad.jpg',
    alt: 'Smoked tri-tip Philly cheesesteak sandwich at Park 101 Carlsbad',
    name: 'Smoked Tri-Tip Philly',
  },
  {
    src: '/images/food/park-101-chicky-chicky-boom-boom-08-carlsbad.jpg',
    alt: 'Tri-tip tacos with chimichurri and cotija at Park 101 Carlsbad',
    name: 'Tri-Tip Tacos',
  },
];

const drinkItems = [
  {
    src: '/images/drinks/park-101-rodeo-tower-prk101-carlsbad.jpg',
    alt: 'Signature Rodeo Tower cocktail display at Park 101 Carlsbad with PRK 101 sign',
  },
  {
    src: '/images/drinks/park-101-dont-mess-with-me-cocktail-carlsbad.jpg',
    alt: "Don't At Me cocktail at Park 101 Carlsbad",
  },
  {
    src: '/images/drinks/park-101-gun-powder-lead-cocktail-carlsbad.jpg',
    alt: 'Gun Powder and Lead cocktail with fresh mint at Park 101 Carlsbad',
  },
  {
    src: '/images/drinks/park-101-talking-irons-cocktail-carlsbad.jpg',
    alt: 'Talking Irons whiskey cocktail on the rooftop at Park 101 Carlsbad',
  },
];
---

<Layout
  title={siteProfile.seo.defaultTitle}
  description={siteProfile.seo.defaultDescription}
  ogImage={siteProfile.seo.ogImage}
  transparentNav={true}
>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-screen w-full bg-brand-dark flex flex-col justify-between overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/venue/park-101-outdoor-rooftop-string-lights-tropical-vibes-carlsbad.jpg"
        alt="Park 101 packed outdoor courtyard with string lights, palm trees, and multi-level venue in Carlsbad Village"
        class="w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/55 to-brand-dark/10"></div>
    </div>

    <div class="h-20 shrink-0"></div>

    <div class="relative z-10 max-w-7xl w-full mx-auto px-6 sm:px-8 lg:px-12 pb-8">
      <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">
        {siteProfile.contact.neighborhood} &middot; One Block From The Beach
      </span>
      <h1 class="font-display font-bold text-hero text-brand-white uppercase leading-ultra tracking-tight max-w-4xl mb-6">
        Where Coast<br />Meets Country
      </h1>
      <p class="font-body font-light text-brand-cream/75 text-lg sm:text-xl max-w-lg mb-8 leading-relaxed">
        {siteProfile.shortDescription}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={siteProfile.ordering.reservationsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
        >
          Reserve a Table
        </a>
        <a
          href="/venue"
          class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
        >
          Explore the Venue
        </a>
      </div>
    </div>

    <!-- Stat Bar -->
    <div class="relative z-10 w-full bg-brand-dark/80 backdrop-blur-sm border-t border-brand-white/10 py-5 sm:py-6">
      <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-y-4 gap-x-4 md:divide-x divide-brand-white/10 text-center">
          {siteProfile.stats.map((stat) => (
            <div class="px-4">
              <span class="block font-display font-bold text-xl sm:text-2xl text-brand-white uppercase tracking-wide leading-tight">{stat.value}</span>
              <span class="block font-body text-[10px] sm:text-xs tracking-stat uppercase text-brand-orange mt-1">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── THE VENUE ─────────────────────────────────────────── -->
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[700px]">
      <div class="relative lg:col-span-7 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/venue/park-101-outdoor-fire-pit-patio-venue-carlsbad.jpg"
          alt="Park 101 full outdoor courtyard at dusk with fire pit seating, LED screen, tables, and multi-level venue"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
      <div class="lg:col-span-5 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            {siteProfile.contact.neighborhood}
          </span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">
            Rooftop.<br />Courtyard.<br />Indoor Bar.
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">
            Three distinct spaces under one open sky. The central courtyard with the massive LED wall. The elevated rooftop deck with views of Carlsbad Village. The indoor bar with wall-to-wall screens and long communal tables. One block from the beach.
          </p>
          <a
            href="/venue"
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            See All Spaces
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SPORTS / GAME DAY ────────────────────────────────── -->
  <section class="relative bg-brand-dark">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[700px]">
      <div class="lg:col-span-5 order-2 lg:order-1 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-dark">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            {siteProfile.venue.sports.headline}
          </span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6">
            Golden Hour.<br />Cold Beer.<br />Big Screens.
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-cream/70 text-base sm:text-lg leading-relaxed mb-8">
            {siteProfile.venue.sports.description}
          </p>
          <div class="flex flex-wrap gap-x-4 gap-y-2 mb-8 pb-8 border-b border-brand-white/10">
            {siteProfile.venue.sports.features.map((feature) => (
              <span class="font-display font-bold text-xs uppercase tracking-feature text-brand-white">{feature}</span>
            ))}
          </div>
          <a
            href="/north-county-lineup"
            class="inline-block px-6 py-3.5 border border-brand-white hover:bg-brand-white hover:text-brand-dark text-brand-white font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            View the Lineup
          </a>
        </div>
      </div>
      <div class="relative lg:col-span-7 order-1 lg:order-2 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/venue/park-101-padres-game-day-packed-venue-carlsbad.jpg"
          alt="Packed crowd at Park 101 Carlsbad during a San Diego Padres game with the Home of the San Diego Padres banner and LED wall"
          class="absolute inset-0 w-full h-full object-cover object-[50%_35%]"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ── FOOD GRID ─────────────────────────────────────────── -->
  <section class="relative bg-brand-cream py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-14">
        <span class="block font-body text-xs font-bold tracking-eyebrow-wide uppercase text-brand-orange mb-3">
          The Kitchen
        </span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase tracking-tight">
          Food Worth Staying For
        </h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5">
        {foodItems.map((item) => (
          <div class="group relative overflow-hidden bg-brand-dark aspect-[4/3]">
            <img
              src={item.src}
              alt={item.alt}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-5">
              <span class="font-display font-bold text-base uppercase tracking-wider text-brand-white">{item.name}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href="/menu"
          class="inline-block px-8 py-4 bg-brand-dark hover:bg-brand-dark/80 text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200"
        >
          View Full Menu
        </a>
      </div>
    </div>
  </section>

  <!-- ── BBQ FEATURE ──────────────────────────────────────── -->
  <section class="relative bg-brand-dark">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[650px]">
      <div class="relative lg:col-span-6 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/food/park-101-loaded-bbq-mac-06-carlsbad.jpg"
          alt="Three BBQ platters of pulled pork, St. Louis ribs, and sliced brisket from the Park 101 smokehouse"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
      <div class="lg:col-span-6 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-dark">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            The Smokehouse
          </span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6">
            Smoked Low.<br />Served Right.
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-cream/70 text-base sm:text-lg leading-relaxed mb-8">
            Brisket. Ribs. Pulled pork. All wood-smoked the right way. Served on a tray with pickles, bread, and sauce — the way it was meant to be eaten. No shortcuts, no compromises.
          </p>
          <a
            href="/menu"
            class="inline-block px-6 py-3.5 border border-brand-white hover:bg-brand-white hover:text-brand-dark text-brand-white font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            Full Smokehouse Menu
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── DRINKS ────────────────────────────────────────────── -->
  <section class="relative bg-brand-steel py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-xl mb-12">
        <span class="block font-body text-xs font-bold tracking-eyebrow-wide uppercase text-brand-orange mb-3">
          The Bar
        </span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight leading-display">
          Cold Drinks.<br />Big Selection.
        </h2>
        <div class="w-12 h-[2px] bg-brand-orange mt-5 mb-5"></div>
        <p class="font-body font-light text-brand-cream/70 text-base sm:text-lg max-w-lg leading-relaxed">
          Signature cocktails, frozen margaritas, local craft beers on draft, and the Rodeo Tower — Park 101's most celebrated creation.
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">
        {drinkItems.map((item) => (
          <div class="relative overflow-hidden bg-brand-dark aspect-square">
            <img
              src={item.src}
              alt={item.alt}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── NORTH COUNTY LINEUP ───────────────────────────────── -->
  <section class="relative min-h-[520px] flex items-center justify-center text-center px-6 py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/venue/park-101-live-music-country-wide-carlsbad.jpg"
        alt="Country guitarist performing live at Park 101 Carlsbad with the LED screen and crowd behind him"
        class="w-full h-full object-cover object-[50%_62%]"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-brand-dark/60"></div>
    </div>
    <div class="relative z-10 max-w-2xl w-full mx-auto">
      <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">
        {siteProfile.venue.liveEvents.headline}
      </span>
      <h2 class="font-display font-bold text-5xl sm:text-6xl text-brand-white uppercase tracking-tight leading-ultra mb-6">
        Live Music.<br />Every Week.
      </h2>
      <p class="font-body font-light text-brand-cream/80 text-base sm:text-lg leading-relaxed mb-8 max-w-lg mx-auto">
        Country nights. Live bands. Padres watch parties. UFC fight nights. From kickoff to the final buzzer, from the first song to last call — something's always happening at Park 101.
      </p>
      <a
        href="/north-county-lineup"
        class="inline-block px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200"
      >
        View the Lineup
      </a>
    </div>
  </section>

  <!-- ── BRUNCH ─────────────────────────────────────────────── -->
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[700px]">
      <div class="lg:col-span-5 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            Saturdays &amp; Sundays
          </span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">
            Brunch on the Rooftop
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">
            Open-air rooftop. Smoked brisket chilaquiles. Breakfast burritos loaded with tri-tip. Rodeo Tower mimosas. The best way to spend a Saturday morning in Carlsbad Village.
          </p>
          <a
            href="/brunch"
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            See the Brunch Menu
          </a>
        </div>
      </div>
      <div class="relative lg:col-span-7 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/brunch/park-101-brunch-chilaquiles-tri-tip-carlsbad.jpg"
          alt="Smoked tri-tip chilaquiles bowl with a fried egg, cotija cheese, pickled onions, and jalapeños at Park 101 weekend brunch"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ── FAMILIES & COMMUNITY ─────────────────────────────── -->
  <section class="relative bg-brand-tan">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[650px]">
      <div class="relative lg:col-span-6 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/venue/park-101-families-kids-game-day-carlsbad.jpg"
          alt="Families and kids in Padres jerseys enjoying game day together at Park 101 Carlsbad"
          class="absolute inset-0 w-full h-full object-cover object-[50%_75%]"
          loading="lazy"
        />
      </div>
      <div class="lg:col-span-6 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-tan">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            {siteProfile.venue.familiesPets.headline}
          </span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">
            Bring the Crew.<br />Bring the Dog.<br />Bring the Kids.
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">
            {siteProfile.venue.familiesPets.description}
          </p>
          <div class="flex flex-wrap gap-2 mb-8">
            {siteProfile.venue.familiesPets.features.map((feature) => (
              <span class="px-3 py-1.5 border border-brand-dark/25 font-display font-bold text-xs uppercase tracking-wide text-brand-dark">{feature}</span>
            ))}
          </div>
          <a
            href="/venue"
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            Plan Your Visit
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PRIVATE EVENTS ────────────────────────────────────── -->
  <section class="relative min-h-[500px] flex items-center justify-center text-center px-6 py-24 overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/venue/park-101-rooftop-evening-group-carlsbad.jpg"
        alt="Evening group gathering on the rooftop at Park 101 Carlsbad with string lights and open-air venue"
        class="w-full h-full object-cover object-center"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-brand-dark/60"></div>
    </div>
    <div class="relative z-10 max-w-2xl w-full mx-auto">
      <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">
        Private Events
      </span>
      <h2 class="font-display font-bold text-5xl sm:text-6xl text-brand-white uppercase tracking-tight leading-ultra mb-6">
        Your Event.<br />Our Venue.
      </h2>
      <p class="font-body font-light text-brand-cream/80 text-base sm:text-lg leading-relaxed mb-8 max-w-lg mx-auto">
        Birthday parties, corporate happy hours, game day buyouts, rehearsal dinners — Park 101's spaces are yours to fill. Book a section, the rooftop, the courtyard, or the whole place.
      </p>
      <a
        href="/private-events"
        class="inline-block px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200"
      >
        Inquire About Events
      </a>
    </div>
  </section>

  <!-- ── BOTTOM INFO BAR ───────────────────────────────────── -->
  <section class="bg-brand-dark border-t border-brand-white/10 py-10 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center justify-between gap-8 text-center lg:text-left">
      <div class="flex flex-col md:flex-row items-center lg:items-start gap-6 md:gap-10">
        <div>
          <span class="block font-display font-bold text-brand-orange text-[10px] tracking-widest uppercase mb-1">Address</span>
          <a
            href={siteProfile.contact.googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-brand-cream/80 hover:text-brand-orange transition-colors duration-150"
          >
            {siteProfile.contact.address.full}
          </a>
        </div>
        <div>
          <span class="block font-display font-bold text-brand-orange text-[10px] tracking-widest uppercase mb-1">Phone</span>
          <a
            href={`tel:${siteProfile.contact.phoneDial}`}
            class="font-body text-sm text-brand-cream/80 hover:text-brand-orange transition-colors duration-150"
          >
            {siteProfile.contact.phone}
          </a>
        </div>
        <div>
          <span class="block font-display font-bold text-brand-orange text-[10px] tracking-widest uppercase mb-1">Hours</span>
          <p class="font-body text-sm text-brand-cream/80">
            Fri–Sun from {siteProfile.hours.friday.open} &middot; Mon–Thu from {siteProfile.hours.monday.open}
          </p>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto flex-shrink-0">
        <a
          href={siteProfile.ordering.toastUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 border border-brand-white/40 hover:border-brand-orange hover:text-brand-orange text-brand-white/70 font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200 text-center whitespace-nowrap"
        >
          Order Takeout
        </a>
        <a
          href={siteProfile.ordering.reservationsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-xs transition-colors duration-200 text-center whitespace-nowrap"
        >
          Reserve a Table
        </a>
      </div>
    </div>
  </section>

</Layout>
