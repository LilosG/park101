---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Where Coast Meets Country | Carlsbad BBQ & Rooftop Bar">
  <section class="relative h-screen w-full overflow-hidden bg-brand-dark flex flex-col justify-between">
    <div class="absolute inset-0 w-full h-full z-0">
      <img 
        src="/images/venue/park-101-outdoor-rooftop-string-lights-tropical-vibes-carlsbad.jpg" 
        alt="Park 101 outdoor courtyard and multi-level rooftop deck with string lights in Carlsbad" 
        class="w-full h-full object-cover object-center transform scale-101"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/45 to-brand-dark/20 z-10"></div>
    </div>

    <div></div>

    <div class="relative z-20 max-w-7xl w-full mx-auto px-6 sm:px-8 lg:px-12 pt-32 text-center md:text-left">
      <span class="inline-block font-sans text-xs sm:text-sm font-bold tracking-[0.3em] uppercase text-brand-orange mb-4">
        Carlsbad Village &middot; One Block From The Beach
      </span>
      <h1 class="font-['Barlow_Condensed'] font-bold text-5xl sm:text-7xl lg:text-8xl text-brand-white uppercase leading-[0.9] tracking-tight max-w-4xl mb-6">
        Where Coast <br class="hidden md:block" />Meets Country
      </h1>
      <p class="font-sans font-light text-brand-cream/80 text-lg sm:text-xl max-w-xl mb-8 leading-relaxed">
        Welcome to Carlsbad’s premier multi-level open-air dining and garden layout. Fresh California air meets wood-fired heritage.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
        <a 
          href="/menu" 
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange/90 text-brand-white font-['Barlow_Condensed'] font-semibold uppercase tracking-[0.1em] text-sm transition-all duration-300 shadow-lg text-center"
        >
          View The Menu
        </a>
        <a 
          href="/private-events" 
          class="px-8 py-4 border border-brand-white hover:bg-brand-white hover:text-brand-dark text-brand-white font-['Barlow_Condensed'] font-semibold uppercase tracking-[0.1em] text-sm transition-all duration-300 text-center"
        >
          Book An Event
        </a>
      </div>
    </div>

    <div class="relative z-20 w-full bg-brand-dark/85 backdrop-blur-md border-t border-brand-white/10 py-6 sm:py-8 mt-12">
      <div class="max-w-7xl w-full mx-auto px-6 sm:px-8 lg:px-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-y-6 gap-x-4 divide-x-0 md:divide-x divide-brand-white/10 text-center">
          <div class="px-2">
            <span class="block font-['Barlow_Condensed'] font-bold text-2xl sm:text-3xl text-brand-white tracking-wide">8,000 SQ FT</span>
            <span class="block font-sans text-[10px] sm:text-xs tracking-[0.2em] uppercase text-brand-orange mt-1 font-medium">Multi-Level Space</span>
          </div>
          <div class="px-2">
            <span class="block font-['Barlow_Condensed'] font-bold text-2xl sm:text-3xl text-brand-white tracking-wide">ROOFTOP DECK</span>
            <span class="block font-sans text-[10px] sm:text-xs tracking-[0.2em] uppercase text-brand-orange mt-1 font-medium">Ocean Air Views</span>
          </div>
          <div class="px-2">
            <span class="block font-['Barlow_Condensed'] font-bold text-2xl sm:text-3xl text-brand-white tracking-wide">GAME DAY HQ</span>
            <span class="block font-sans text-[10px] sm:text-xs tracking-[0.2em] uppercase text-brand-orange mt-1 font-medium">Massive LED Wall</span>
          </div>
          <div class="px-2">
            <span class="block font-['Barlow_Condensed'] font-bold text-2xl sm:text-3xl text-brand-white tracking-wide">PET FRIENDLY</span>
            <span class="block font-sans text-[10px] sm:text-xs tracking-[0.2em] uppercase text-brand-orange mt-1 font-medium">Dogs Welcome Always</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative bg-brand-cream min-h-[700px] flex items-center overflow-hidden border-b border-brand-dark/5">
    <div class="w-full grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[700px]">
      <div class="relative lg:col-span-7 min-h-[350px] lg:min-h-full">
        <img 
          src="/images/venue/park-101-rooftop-bar-lounge-venue-carlsbad.jpg" 
          alt="Park 101 open rooftop deck bar lounge at golden hour" 
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
      <div class="lg:col-span-5 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-sans text-xs font-bold tracking-[0.25em] uppercase text-brand-orange mb-3">
            The Garden Rooftop
          </span>
          <h2 class="font-['Barlow_Condensed'] font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-[0.95] tracking-tight mb-6">
            Two Levels.<br />One View.<br />All Carlsbad.
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-sans font-light text-brand-dark/80 text-base sm:text-lg leading-relaxed mb-8">
            Escape to the Garden Rooftop Lounge, where coastal vibes meet village sights. Enjoy refreshing signature cocktails, crisp local craft microbrews, and shared plates curated for sun-soaked afternoons and fire pit conversations.
          </p>
          <a 
            href="/venue/rooftop" 
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-['Barlow_Condensed'] font-semibold uppercase tracking-[0.1em] text-xs transition-all duration-300"
          >
            Explore The Rooftop
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="relative bg-brand-dark min-h-[700px] flex items-center overflow-hidden">
    <div class="w-full grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[700px]">
      <div class="lg:col-span-5 order-2 lg:order-1 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-dark z-10">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-sans text-xs font-bold tracking-[0.25em] uppercase text-brand-orange mb-3">
            Sports Headquarters
          </span>
          <h2 class="font-['Barlow_Condensed'] font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-[0.95] tracking-tight mb-6">
            Your Stadium Experience In The Village
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-sans font-light text-brand-cream/70 text-base sm:text-lg leading-relaxed mb-8">
            Catch every second of action on our massive outdoor plaza LED wall. With complete multi-game sound capabilities, vibrant fan energy, and direct table-service drink buckets, we turn game days into local celebrations.
          </p>
          
          <div class="flex flex-wrap gap-x-6 gap-y-3 mb-8 pb-8 border-b border-brand-white/10">
            <span class="font-['Barlow_Condensed'] font-semibold text-sm uppercase tracking-[0.15em] text-brand-white">NFL TICKET</span>
            <span class="text-brand-orange/40">&middot;</span>
            <span class="font-['Barlow_Condensed'] font-semibold text-sm uppercase tracking-[0.15em] text-brand-white">UFC MAIN CARDS</span>
            <span class="text-brand-orange/40">&middot;</span>
            <span class="font-['Barlow_Condensed'] font-semibold text-sm uppercase tracking-[0.15em] text-brand-white">PADRES HQ</span>
            <span class="text-brand-orange/40">&middot;</span>
            <span class="font-['Barlow_Condensed'] font-semibold text-sm uppercase tracking-[0.15em] text-brand-white">FANTASY</span>
          </div>

          <a 
            href="/venue/sports" 
            class="inline-block px-6 py-3.5 border border-brand-white hover:bg-brand-white hover:text-brand-dark text-brand-white font-['Barlow_Condensed'] font-semibold uppercase tracking-[0.1em] text-xs transition-all duration-300"
          >
            Game Day Schedules
          </a>
        </div>
      </div>
      <div class="relative lg:col-span-7 order-1 lg:order-2 min-h-[350px] lg:min-h-full">
        <img 
          src="/images/venue/park-101-outdoor-rooftop-sports-bar-lounge-carlsbad.jpg" 
          alt="Fans gathering around custom fire pits to watch sports on the giant LED wall screen" 
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="relative bg-brand-cream py-24 px-6 sm:px-8 lg:px-12 border-b border-brand-dark/5">
    <div class="max-w-7xl w-full mx-auto">
      <div class="text-center max-w-xl mx-auto mb-16">
        <span class="block font-sans text-xs font-bold tracking-[0.3em] uppercase text-brand-orange mb-3">
          The Kitchen
        </span>
        <h2 class="font-['Barlow_Condensed'] font-bold text-4xl sm:text-5xl text-brand-dark uppercase tracking-tight">
          Food Worth Staying For
        </h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-4 mb-4"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        <div class="group relative overflow-hidden bg-brand-dark shadow-md aspect-[4/3]">
          <img src="/images/food/park-101-prk-food-spread-02-carlsbad.jpg" alt="Overhead flatlay spread of Park 101 signature items" class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
            <span class="font-['Barlow_Condensed'] font-semibold text-lg uppercase tracking-wide text-brand-white">Signature Food Spread</span>
          </div>
        </div>
        <div class="group relative overflow-hidden bg-brand-dark shadow-md aspect-[4/3]">
          <img src="/images/food/park-101-smoked-tri-tip-carlsbad.jpg" alt="House smoked premium Tri-Tip plate slice" class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
            <span class="font-['Barlow_Condensed'] font-semibold text-lg uppercase tracking-wide text-brand-white">Smoked Tri-Tip Platter</span>
          </div>
        </div>
        <div class="group relative overflow-hidden bg-brand-dark shadow-md aspect-[4/3]">
          <img src="/images/food/park-101-shrimp-tacos-04-carlsbad.jpg" alt="Gourmet crisp shrimp tacos with fresh lime" class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
            <span class="font-['Barlow_Condensed'] font-semibold text-lg uppercase tracking-wide text-brand-white">Coastal Shrimp Tacos</span>
          </div>
        </div>
        <div class="group relative overflow-hidden bg-brand-dark shadow-md aspect-[4/3]">
          <img src="/images/food/park-101-rodeo-barrel-nachos-carlsbad.jpg" alt="Stacked Rodeo Barrel nachos with smoked meats cheese sauces" class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
            <span class="font-['Barlow_Condensed'] font-semibold text-lg uppercase tracking-wide text-brand-white">Rodeo Barrel Nachos</span>
          </div>
        </div>
        <div class="group relative overflow-hidden bg-brand-dark shadow-md aspect-[4/3]">
          <img src="/images/food/park-101-loaded-bbq-mac-carlsbad.jpg" alt="Loaded skillet baked BBQ mac and cheese" class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
            <span class="font-['Barlow_Condensed'] font-semibold text-lg uppercase tracking-wide text-brand-white">Loaded BBQ Mac & Cheese</span>
          </div>
        </div>
        <div class="group relative overflow-hidden bg-brand-dark shadow-md aspect-[4/3]">
          <img src="/images/food/park-101-chicky-chicky-boom-boom-carlsbad.jpg" alt="Crisp premium chicken sandwich with house pickles" class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
            <span class="font-['Barlow_Condensed'] font-semibold text-lg uppercase tracking-wide text-brand-white">Chicky Chicky Boom Boom</span>
          </div>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a 
          href="/menu" 
          class="inline-block px-8 py-4 bg-brand-dark hover:bg-brand-dark/90 text-brand-white font-['Barlow_Condensed'] font-semibold uppercase tracking-[0.15em] text-sm transition-all duration-300 shadow-md"
        >
          View Full Menu Offerings
        </a>
      </div>
    </div>
  </section>

  <section class="relative bg-brand-dark min-h-[650px] flex items-center overflow-hidden">
    <div class="w-full grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[650px]">
      <div class="relative lg:col-span-6 min-h-[350px] lg:min-h-full">
        <img 
          src="/images/food/park-101-prk-smoked-meats-carlsbad.jpg" 
          alt="Artisanal smoked house brisket and premium rib platter spreads from our smokehouse" 
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
      <div class="lg:col-span-6 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-dark">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-sans text-xs font-bold tracking-[0.25em] uppercase text-brand-orange mb-3">
            The Brisket Shack Program
          </span>
          <h2 class="font-['Barlow_Condensed'] font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-[0.95] tracking-tight mb-6">
            Smoked Low.<br />Served Right.
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-sans font-light text-brand-cream/70 text-base sm:text-lg leading-relaxed mb-8">
            Our traditional wood-fired pits work round-the-clock. We source choice cuts, rub them simply with premium spice mixtures, and smoke them slowly over select hardwood species to create fall-off-the-bone tenderness and rich, smoky crust structures.
          </p>
          <a 
            href="/menu" 
            class="inline-block px-6 py-3.5 border border-brand-white hover:bg-brand-white hover:text-brand-dark text-brand-white font-['Barlow_Condensed'] font-semibold uppercase tracking-[0.1em] text-xs transition-all duration-300"
          >
            Smokehouse Selections
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="relative bg-brand-steel py-24 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl w-full mx-auto">
      <div class="flex flex-col lg:flex-row items-start lg:items-end justify-between mb-12">
        <div class="max-w-xl">
          <span class="block font-sans text-xs font-bold tracking-[0.3em] uppercase text-brand-orange mb-3">
            The Beverage Program
          </span>
          <h2 class="font-['Barlow_Condensed'] font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight">
            Cold Drinks. Big Selection.
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mt-4 mb-4 lg:mb-0"></div>
        </div>
        <p class="font-sans font-light text-brand-cream/70 text-base sm:text-lg max-w-md">
          From crisp regional Southern California draft IPAs to bright, hand-shaken artisanal tropical cocktails layered with seasonal flowers.
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
        <div class="relative overflow-hidden bg-brand-dark aspect-square shadow-md">
          <img src="/images/drinks/park-101-pink-cocktail-flower-garnish-carlsbad.jpg" alt="Signature pink craft cocktail with delicate floral garnishes" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="relative overflow-hidden bg-brand-dark aspect-square shadow-md">
          <img src="/images/drinks/park-101-spiced-rim-citrus-cocktail-carlsbad.jpg" alt="Citrus margarita profile cocktail with custom spiced salt rimming" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="relative overflow-hidden bg-brand-dark aspect-square shadow-md">
          <img src="/images/drinks/park-101-tropical-pink-cocktail-garnish-carlsbad.jpg" alt="Vibrant tropical cocktail configuration with citrus leaf additions" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="relative overflow-hidden bg-brand-dark aspect-square shadow-md">
          <img src="/images/brunch/park-101-brunch-dsc08255-carlsbad.jpg" alt="House special loaded signature Bloody Mary profile item" class="w-full h-full object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="relative min-h-[450px] w-full flex items-center justify-center text-center px-6 py-20 overflow-hidden bg-brand-dark">
    <div class="absolute inset-0 w-full h-full">
      <img 
        src="/images/venue/park-101-outdoor-venue-string-lights-live-music-carlsbad.jpg" 
        alt="Crowds enjoying an active live performance setup under complex string lighting designs" 
        class="w-full h-full object-cover object-center"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-brand-dark/75 backdrop-blur-[1px]"></div>
    </div>

    <div class="relative z-10 max-w-2xl w-full mx-auto">
      <span class="inline-block font-sans text-xs font-bold tracking-[0.3em] uppercase text-brand-orange mb-4">
        Weekly Entertainment
      </span>
      <h2 class="font-['Barlow_Condensed'] font-bold text-4xl sm:text-6xl text-brand-white uppercase tracking-tight mb-6">
        Live Music. Every Week.
      </h2>
      <p class="font-sans font-light text-brand-cream/80 text-base sm:text-lg leading-relaxed mb-8">
        We gather top regional artists, acoustic performance sets, and dynamic weekend curators directly underneath the open coastal evening sky. Check out our upcoming calendar listings.
      </p>
      <a 
        href="/venue/live-events" 
        class="inline-block px-8 py-4 bg-brand-orange hover:bg-brand-orange/90 text-brand-white font-['Barlow_Condensed'] font-semibold uppercase tracking-[0.1em] text-sm transition-all duration-300 shadow-xl"
      >
        View Events Calendar
      </a>
    </div>
  </section>

  <section class="relative bg-brand-cream min-h-[700px] flex items-center overflow-hidden border-b border-brand-dark/5">
    <div class="w-full grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[700px]">
      <div class="lg:col-span-5 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-sans text-xs font-bold tracking-[0.25em] uppercase text-brand-orange mb-3">
            Weekend Rituals
          </span>
          <h2 class="font-['Barlow_Condensed'] font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-[0.95] tracking-tight mb-6">
            Brunch On The Rooftop
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-sans font-light text-brand-dark/80 text-base sm:text-lg leading-relaxed mb-8">
            Elevate your weekends with our exclusive open-air rooftop brunch. Indulge in wood-fired morning hashes, loaded breakfast skillets, and shared cocktail flights designed around local sunrays. Served Saturdays and Sundays.
          </p>
          <a 
            href="/menu" 
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-['Barlow_Condensed'] font-semibold uppercase tracking-[0.1em] text-xs transition-all duration-300"
          >
            Explore Brunch Menu
          </a>
        </div>
      </div>
      <div class="relative lg:col-span-7 min-h-[350px] lg:min-h-full">
        <img 
          src="/images/brunch/park-101-brunch-dsc03776-carlsbad.jpg" 
          alt="Overhead visualization of premium house smoked tri-tip chilaquiles bowl with fried egg decorations" 
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <section class="relative bg-brand-tan py-20 px-6 sm:px-8 lg:px-12 text-center">
    <div class="max-w-5xl w-full mx-auto">
      <span class="inline-block font-sans text-xs font-bold tracking-[0.3em] uppercase text-brand-orange mb-4">
        Community Courtyard Space
      </span>
      <h2 class="font-['Barlow_Condensed'] font-bold text-3xl sm:text-5xl text-brand-dark uppercase tracking-tight mb-12">
        Families Welcome. Dogs Welcome. Everyone's Welcome.
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center max-w-4xl mx-auto mb-12">
        <div class="px-4 py-6 bg-brand-cream/40 rounded-sm">
          <span class="block font-['Barlow_Condensed'] font-bold text-xl text-brand-dark tracking-wide uppercase mb-2">FAMILIES</span>
          <p class="font-sans font-light text-brand-dark/70 text-sm">Spacious outdoor seating areas with casual lawn configurations perfect for gathering across generations.</p>
        </div>
        <div class="px-4 py-6 bg-brand-cream/40 rounded-sm">
          <span class="block font-['Barlow_Condensed'] font-bold text-xl text-brand-dark tracking-wide uppercase mb-2">PETS</span>
          <p class="font-sans font-light text-brand-dark/70 text-sm">Dedicated fresh water bowl allocations and curated premium pet-friendly house biscuits for your companion.</p>
        </div>
        <div class="px-4 py-6 bg-brand-cream/40 rounded-sm">
          <span class="block font-['Barlow_Condensed'] font-bold text-xl text-brand-dark tracking-wide uppercase mb-2">KIDS</span>
          <p class="font-sans font-light text-brand-dark/70 text-sm">Safe environment choices alongside intentional healthy menu variations crafted directly for little appetites.</p>
        </div>
      </div>

      <a 
        href="/venue/families-pets" 
        class="inline-block px-8 py-4 bg-brand-dark hover:bg-brand-dark/90 text-brand-white font-['Barlow_Condensed'] font-semibold uppercase tracking-[0.1em] text-sm transition-all duration-300 shadow-md"
      >
        Plan Your Group Visit
      </a>
    </div>
  </section>

  <section class="relative min-h-[450px] w-full flex items-center justify-center text-center px-6 py-20 overflow-hidden bg-brand-dark">
    <div class="absolute inset-0 w-full h-full">
      <img 
        src="/images/venue/park-101-outdoor-fire-pit-patio-venue-carlsbad.jpg" 
        alt="Atmospheric fire pit circular seating spaces under premium twilight tones" 
        class="w-full h-full object-cover object-center"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-brand-dark/80"></div>
    </div>

    <div class="relative z-10 max-w-2xl w-full mx-auto">
