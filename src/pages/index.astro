---
import Layout from '../layouts/Layout.astro';
import siteProfile from '../data/site-profile.json';
---

<Layout
  title="Park 101 — Rooftop Bar, BBQ & Game Day HQ | Carlsbad Village CA"
  description="Park 101 is Carlsbad's rooftop bar and game day headquarters. BBQ, craft cocktails, live music, weekend brunch, and private events — one block from the beach in Carlsbad Village."
  transparentNav={true}
>

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="relative h-screen min-h-[680px] flex flex-col overflow-hidden">
    <img
      src="/images/venue/park-101-outdoor-rooftop-string-lights-tropical-vibes-carlsbad.jpg"
      alt="Park 101 outdoor rooftop courtyard with string lights at night — Carlsbad Village CA"
      class="absolute inset-0 w-full h-full object-cover object-center"
      fetchpriority="high"
      loading="eager"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(27,20,15,0.95) 0%, rgba(27,20,15,0.52) 38%, rgba(27,20,15,0.12) 68%, transparent 100%);"></div>

    <div class="relative z-10 flex flex-col justify-center flex-1 px-6 pb-44 pt-32 max-w-7xl mx-auto w-full">
      <p class="text-[10px] font-bold tracking-[0.38em] uppercase text-brand-orange mb-5">
        Carlsbad Village &nbsp;·&nbsp; One Block From The Beach
      </p>
      <h1
        class="font-display font-black uppercase leading-none mb-6"
        style="font-size: clamp(4rem, 11vw, 8.5rem); letter-spacing: -0.02em; line-height: 0.90; color: #FDFAF7;"
      >
        Where Coast<br/>Meets Country
      </h1>
      <p class="text-lg leading-relaxed max-w-lg mb-10" style="color: rgba(253,250,247,0.75);">
        Carlsbad's rooftop bar and game day headquarters. BBQ, craft cocktails,
        live music, weekend brunch, and private events — all under the open sky.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/menu" class="px-9 py-4 text-[11px] font-bold tracking-[0.22em] uppercase bg-brand-orange hover:bg-brand-brown transition-all duration-300" style="color: #FDFAF7;">
          View the Menu
        </a>
        <a href="https://tables.toasttab.com/restaurants/b853a506-313a-4be5-99d2-ffaf0c250021/findTime" target="_blank" rel="noopener noreferrer" class="px-9 py-4 text-[11px] font-bold tracking-[0.22em] uppercase hover:bg-white/10 transition-all duration-300" style="border: 2px solid rgba(253,250,247,0.60); color: #FDFAF7;">
          Reserve a Table
        </a>
      </div>
    </div>

    <!-- Stat bar pinned to bottom inside hero -->
    <div class="absolute bottom-0 left-0 right-0 z-10" style="background: rgba(27,20,15,0.93); border-top: 1px solid rgba(253,250,247,0.08);">
      <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4">
        <div class="flex flex-col items-center justify-center py-5 px-4 gap-1" style="border-right: 1px solid rgba(255,255,255,0.09);">
          <span class="font-display font-black text-xl uppercase tracking-wide text-brand-orange">8,000</span>
          <span class="text-[10px] font-bold tracking-[0.28em] uppercase" style="color: rgba(253,250,247,0.45);">Sq Ft Venue</span>
        </div>
        <div class="flex flex-col items-center justify-center py-5 px-4 gap-1" style="border-right: 1px solid rgba(255,255,255,0.09);">
          <span class="font-display font-black text-xl uppercase tracking-wide text-brand-orange">Rooftop</span>
          <span class="text-[10px] font-bold tracking-[0.28em] uppercase" style="color: rgba(253,250,247,0.45);">Deck &amp; Bar</span>
        </div>
        <div class="flex flex-col items-center justify-center py-5 px-4 gap-1" style="border-right: 1px solid rgba(255,255,255,0.09);">
          <span class="font-display font-black text-xl uppercase tracking-wide text-brand-orange">Game Day</span>
          <span class="text-[10px] font-bold tracking-[0.28em] uppercase" style="color: rgba(253,250,247,0.45);">Headquarters</span>
        </div>
        <div class="flex flex-col items-center justify-center py-5 px-4 gap-1">
          <span class="font-display font-black text-xl uppercase tracking-wide text-brand-orange">Pet &amp; Family</span>
          <span class="text-[10px] font-bold tracking-[0.28em] uppercase" style="color: rgba(253,250,247,0.45);">Friendly</span>
        </div>
      </div>
    </div>
  </section>


  <!-- ─── EDITORIAL INTRO — brand story, image left copy right ─── -->
  <!-- Same pattern as Miss B's "Where San Diego Comes to Drink Well" section -->
  <section class="bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[700px]">
      <div class="relative min-h-[460px] lg:min-h-full order-2 lg:order-1">
        <img
          src="/images/venue/park-101-outdoor-rooftop-bar-evening-crowd-carlsbad.jpg"
          alt="Park 101 rooftop crowd under string lights — Carlsbad Village CA"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
      <div class="flex flex-col justify-center px-10 py-20 lg:px-16 xl:px-20 order-1 lg:order-2">
        <p class="text-[10px] font-bold tracking-[0.38em] uppercase text-brand-orange mb-5">
          Carlsbad Village
        </p>
        <h2
          class="font-display font-black uppercase leading-none mb-5"
          style="font-size: clamp(2.75rem, 6vw, 5rem); line-height: 0.92; color: var(--color-brand-dark);"
        >
          Where Carlsbad<br/>Comes Together
        </h2>
        <div class="h-px w-16 bg-brand-orange mb-7"></div>
        <p class="text-base leading-relaxed mb-4 max-w-[44ch]" style="color: var(--color-brand-steel);">
          Park 101 is 8,000 square feet of open-air rooftop, fire pits, big screens,
          and cold drinks — one block from the beach in Carlsbad Village. Two levels,
          one courtyard, no roof overhead. Just palm trees and California sky.
        </p>
        <p class="text-base leading-relaxed mb-10 max-w-[44ch]" style="color: var(--color-brand-steel);">
          Come for the game. Stay for the BBQ. Bring the whole group — including the dog.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/venue/rooftop" class="px-8 py-4 text-[11px] font-bold tracking-[0.22em] uppercase transition-all duration-200" style="background: var(--color-brand-dark); color: #FDFAF7;">
            See the Venue
          </a>
          <a href="/private-events" class="px-8 py-4 text-[11px] font-bold tracking-[0.22em] uppercase transition-all duration-200" style="border: 1px solid rgba(27,20,15,0.25); color: var(--color-brand-dark);">
            Private Events
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- ─── GAME DAY SPLIT — copy left, image right, dark ────────── -->
  <section style="background: var(--color-brand-dark);">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[720px]">
      <div class="flex flex-col justify-center px-10 py-24 lg:px-16 xl:px-20 order-2 lg:order-1">
        <p class="text-[10px] font-bold tracking-[0.38em] uppercase text-brand-orange mb-5">Game Day HQ</p>
        <h2
          class="font-display font-black uppercase leading-none mb-5"
          style="font-size: clamp(2.75rem, 6vw, 5rem); line-height: 0.92; color: #FDFAF7;"
        >
          North County's<br/>Outdoor<br/>Stadium.
        </h2>
        <div class="h-px w-16 bg-brand-orange mb-7"></div>
        <p class="text-base leading-relaxed mb-8 max-w-[44ch]" style="color: rgba(253,250,247,0.70);">
          Massive LED wall. Fire pit seating. Cold beer by the bucket. When the
          game is on, there is no better seat in Carlsbad than Park 101's open-air rooftop.
        </p>
        <div class="flex flex-wrap gap-3 mb-10">
          {['NFL', 'UFC', 'Padres', 'NBA', 'Fantasy'].map(sport => (
            <span class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.2em] text-brand-orange" style="border: 1px solid rgba(196,98,45,0.50);">
              {sport}
            </span>
          ))}
        </div>
        <a href="/venue/sports" class="self-start px-8 py-4 text-[11px] font-bold tracking-[0.22em] uppercase bg-brand-orange hover:bg-brand-brown transition-all duration-200" style="color: #FDFAF7;">
          Game Day Details
        </a>
      </div>
      <div class="relative min-h-[480px] lg:min-h-full order-1 lg:order-2">
        <img
          src="/images/venue/park-101-outdoor-rooftop-sports-bar-lounge-carlsbad.jpg"
          alt="Park 101 rooftop sports bar with LED wall and fire pit seating — Carlsbad CA"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
        <div class="absolute inset-0 hidden lg:block" style="background: linear-gradient(to right, rgba(27,20,15,0.55) 0%, transparent 45%);"></div>
      </div>
    </div>
  </section>


  <!-- ─── FOOD SECTION — cream, 3-col grid ─────────────────────── -->
  <section class="bg-brand-cream py-28 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-14">
        <div class="flex flex-col gap-4">
          <p class="text-[10px] font-bold tracking-[0.38em] uppercase text-brand-orange">The Kitchen</p>
          <h2
            class="font-display font-black uppercase leading-none"
            style="font-size: clamp(2.75rem, 6vw, 5rem); line-height: 0.92; color: var(--color-brand-dark);"
          >
            Food Worth<br/>Staying For
          </h2>
          <div class="h-px w-16 bg-brand-orange"></div>
        </div>
        <a href="/menu" class="shrink-0 px-8 py-4 text-[11px] font-bold tracking-[0.22em] uppercase transition-all duration-200" style="border: 1px solid rgba(27,20,15,0.25); color: var(--color-brand-dark);">
          Full Menu
        </a>
      </div>
      <!-- 3-col grid, first item spans 2 rows — same pattern as Miss B's food grid -->
      <div class="grid grid-cols-3 gap-2">
        <!-- Hero item — left col, row-span-2 -->
        <div class="group relative overflow-hidden row-span-2">
          <img
            src="/images/food/park-101-prk-smoked-meats-carlsbad.jpg"
            alt="Park 101 smoked meats platter — Carlsbad CA"
            class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 flex items-end p-5 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(to top, rgba(27,20,15,0.82) 0%, transparent 60%);">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em]" style="color: #FDFAF7;">Smoked Meats Platter</span>
          </div>
        </div>
        <!-- Right 4 items — 2x2 aspect-square -->
        {[
          { src: '/images/food/park-101-shrimp-tacos-04-carlsbad.jpg', label: 'Shrimp Tacos' },
          { src: '/images/food/park-101-rodeo-barrel-nachos-carlsbad.jpg', label: 'Rodeo Barrel Nachos' },
          { src: '/images/food/park-101-loaded-bbq-mac-carlsbad.jpg', label: 'Loaded BBQ Mac' },
          { src: '/images/food/park-101-chicky-chicky-boom-boom-carlsbad.jpg', label: 'Chicky Chicky Boom Boom' },
        ].map(item => (
          <div class="group relative overflow-hidden aspect-square">
            <img
              src={item.src}
              alt={item.label + " — Park 101 Carlsbad"}
              class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 flex items-end p-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(to top, rgba(27,20,15,0.82) 0%, transparent 60%);">
              <span class="text-[10px] font-bold uppercase tracking-[0.2em]" style="color: #FDFAF7;">{item.label}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ─── BBQ FEATURE — full-bleed image, left overlay ─────────── -->
  <!-- Same structure as Miss B's cocktail feature section -->
  <section class="relative overflow-hidden min-h-[680px] flex items-center">
    <img
      src="/images/venue/park-101-outdoor-rooftop-bbq-gathering-carlsbad.jpg"
      alt="Park 101 rooftop BBQ gathering — Carlsbad Village CA"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="lazy"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(27,20,15,0.92) 0%, rgba(27,20,15,0.60) 55%, transparent 100%);"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 py-24">
      <div class="max-w-lg flex flex-col gap-6">
        <p class="text-[10px] font-bold tracking-[0.38em] uppercase text-brand-orange">
          The Brisket Shack
        </p>
        <h2
          class="font-display font-black uppercase leading-none"
          style="font-size: clamp(3rem, 7vw, 5.5rem); line-height: 0.90; color: #FDFAF7;"
        >
          Smoked Low.<br/>Served Right.
        </h2>
        <div class="h-px w-16 bg-brand-orange"></div>
        <p class="text-base leading-relaxed" style="color: rgba(253,250,247,0.78);">
          Real wood smoke. Real time. Brisket, tri-tip, and St. Louis ribs
          low-and-slow until they are right — then served on trays alongside
          house sides that earn their spot on the table.
        </p>
        <a href="/menu" class="self-start px-8 py-4 text-[11px] font-bold tracking-[0.22em] uppercase bg-brand-orange hover:bg-brand-brown transition-all duration-200" style="color: #FDFAF7;">
          See the Menu
        </a>
      </div>
    </div>
  </section>


  <!-- ─── DRINKS SPLIT — copy left, image right, cream ─────────── -->
  <section class="bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[680px]">
      <div class="flex flex-col justify-center px-10 py-24 lg:px-16 xl:px-20 order-2 lg:order-1">
        <p class="text-[10px] font-bold tracking-[0.38em] uppercase text-brand-orange mb-5">Bar Program</p>
        <h2
          class="font-display font-black uppercase leading-none mb-5"
          style="font-size: clamp(2.75rem, 6vw, 5rem); line-height: 0.92; color: var(--color-brand-dark);"
        >
          Cold Drinks.<br/>Big Selection.
        </h2>
        <div class="h-px w-16 bg-brand-orange mb-7"></div>
        <p class="text-base leading-relaxed mb-8 max-w-[44ch]" style="color: var(--color-brand-steel);">
          Craft cocktails built for the California sun. 30+ beers on draft,
          frozen drinks, and a full wine list — poured rooftop, always cold.
        </p>
        <ul class="flex flex-col gap-3 mb-10">
          {['Craft Cocktail Program', '30+ Beers On Draft', 'Frozen Drinks', 'Full Wine List'].map(item => (
            <li class="flex items-center gap-3 text-sm" style="color: var(--color-brand-steel);">
              <div class="h-px w-5 bg-brand-orange shrink-0"></div>
              {item}
            </li>
          ))}
        </ul>
        <a href="/menu" class="self-start px-8 py-4 text-[11px] font-bold tracking-[0.22em] uppercase transition-all duration-200" style="background: var(--color-brand-dark); color: #FDFAF7;">
          View the Bar Menu
        </a>
      </div>
      <div class="relative min-h-[480px] lg:min-h-full order-1 lg:order-2">
        <img
          src="/images/venue/park-101-craft-beer-tap-selection-carlsbad.jpg"
          alt="Park 101 craft beer tap selection — Carlsbad Village CA"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ─── DRINKS GRID — 6 cocktail images flush no-gap ────────── -->
  <section class="bg-brand-cream pb-28">
    <div class="grid grid-cols-2 md:grid-cols-3">
      {[
        { src: '/images/drinks/park-101-pink-cocktail-flower-garnish-carlsbad.jpg', label: 'Craft Cocktails' },
        { src: '/images/drinks/park-101-spiced-rim-citrus-cocktail-carlsbad.jpg', label: 'Spiced Citrus' },
        { src: '/images/drinks/park-101-tropical-pink-cocktail-garnish-carlsbad.jpg', label: 'Tropical Program' },
        { src: '/images/drinks/park-101-peachy-cocktail-flower-garnish-carlsbad.jpg', label: 'Peachy Cocktail' },
        { src: '/images/drinks/park-101-sunflower-cocktail-arrangement-bar-carlsbad.jpg', label: 'Bar Arrangements' },
        { src: '/images/drinks/park-101-pink-cocktail-foam-garnish-carlsbad.jpg', label: 'Foam Cocktail' },
      ].map(item => (
        <div class="group relative overflow-hidden aspect-[4/3]">
          <img
            src={item.src}
            alt={item.label + " — Park 101 Carlsbad"}
            class="w-full h-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 flex items-end p-5 opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(to top, rgba(27,20,15,0.82) 0%, transparent 60%);">
            <span class="text-[10px] font-bold uppercase tracking-[0.2em]" style="color: #FDFAF7;">{item.label}</span>
          </div>
        </div>
      ))}
    </div>
  </section>


  <!-- ─── LIVE EVENTS CTA BAND ──────────────────────────────────── -->
  <section class="relative overflow-hidden min-h-[600px] flex items-center">
    <img
      src="/images/venue/park-101-outdoor-firepit-string-lights-evening-crowd-carlsbad.jpg"
      alt="Live events and crowd at Park 101 — Carlsbad CA"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="lazy"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(27,20,15,0.94) 0%, rgba(27,20,15,0.68) 50%, rgba(27,20,15,0.38) 100%);"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 py-32 flex flex-col items-center text-center gap-6">
      <p class="text-[10px] font-bold tracking-[0.38em] uppercase text-brand-orange">Every Week</p>
      <h2
        class="font-display font-black uppercase leading-none"
        style="font-size: clamp(3.5rem, 8vw, 6.5rem); line-height: 0.90; color: #FDFAF7;"
      >
        Live Music.<br/>Every Week.
      </h2>
      <div class="h-px w-16 bg-brand-orange"></div>
      <p class="text-base leading-relaxed max-w-lg" style="color: rgba(253,250,247,0.75);">
        Trivia nights, live bands, themed events, and weekly specials on the Tamarack Deck.
        There is always something on the rooftop.
      </p>
      <a href="/venue/live-events" class="mt-2 px-10 py-4 text-[11px] font-bold tracking-[0.22em] uppercase bg-brand-orange hover:bg-brand-brown transition-all duration-300" style="color: #FDFAF7;">
        See What's On
      </a>
    </div>
  </section>


  <!-- ─── BRUNCH SPLIT — copy left, image right, cream ─────────── -->
  <section class="bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[720px]">
      <div class="flex flex-col justify-center px-10 py-24 lg:px-16 xl:px-20 order-2 lg:order-1">
        <p class="text-[10px] font-bold tracking-[0.38em] uppercase text-brand-orange mb-5">Saturday &amp; Sunday</p>
        <h2
          class="font-display font-black uppercase leading-none mb-5"
          style="font-size: clamp(2.75rem, 6vw, 5rem); line-height: 0.92; color: var(--color-brand-dark);"
        >
          Brunch on<br/>the Rooftop.
        </h2>
        <div class="h-px w-16 bg-brand-orange mb-7"></div>
        <p class="text-base leading-relaxed mb-8 max-w-[44ch]" style="color: var(--color-brand-steel);">
          Every Saturday and Sunday from 10am. Tri-tip chilaquiles, loaded brunch
          plates, Bloody Marys, and bottomless mimosas on the open rooftop deck.
        </p>
        <div class="inline-flex items-center gap-3 px-5 py-3 mb-10 self-start border-l-2 border-brand-orange" style="background: rgba(196,154,106,0.25);">
          <span class="text-[11px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-brand-dark);">Sat &amp; Sun &nbsp;·&nbsp; 10am – 3pm</span>
        </div>
        <a href="/menu" class="self-start px-8 py-4 text-[11px] font-bold tracking-[0.22em] uppercase transition-all duration-200" style="background: var(--color-brand-dark); color: #FDFAF7;">
          Brunch Menu
        </a>
      </div>
      <div class="relative min-h-[480px] lg:min-h-full order-1 lg:order-2">
        <img
          src="/images/brunch/park-101-brunch-dsc03776-carlsbad.jpg"
          alt="Tri-tip chilaquiles with fried egg — Park 101 rooftop brunch Carlsbad CA"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
    </div>
  </section>


  <!-- ─── FAMILIES + PETS — two-image left, copy right, tan ───── -->
  <section style="background: var(--color-brand-tan);">
    <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[640px]">
      <div class="grid grid-cols-2 min-h-[420px] lg:min-h-full">
        <div class="relative">
          <img
            src="/images/venue/park-101-outdoor-patio-sunny-casual-crowd-carlsbad.jpg"
            alt="Families and guests enjoying Park 101 outdoor patio — Carlsbad CA"
            class="absolute inset-0 w-full h-full object-cover object-center"
            loading="lazy"
          />
        </div>
        <div class="relative">
          <img
            src="/images/venue/park-101-outdoor-family-friendly-gathering-carlsbad.jpg"
            alt="Outdoor family-friendly gathering at Park 101 — Carlsbad CA"
            class="absolute inset-0 w-full h-full object-cover object-center"
            loading="lazy"
          />
        </div>
      </div>
      <div class="flex flex-col justify-center px-10 py-24 lg:px-16 xl:px-20">
        <p class="text-[10px] font-bold tracking-[0.38em] uppercase text-brand-orange mb-5">Open to Everyone</p>
        <h2
          class="font-display font-black uppercase leading-none mb-5"
          style="font-size: clamp(2.25rem, 5vw, 3.75rem); line-height: 0.92; color: var(--color-brand-dark);"
        >
          Families Welcome.<br/>Dogs Welcome.<br/>Everyone's Welcome.
        </h2>
        <div class="h-px w-16 bg-brand-orange mb-7"></div>
        <p class="text-base leading-relaxed mb-10 max-w-[44ch]" style="color: rgba(27,20,15,0.75);">
          Park 101 is an outdoor venue built for real life. Bring your crew,
          bring your kids, bring your dog. No stuffiness — come as you are.
        </p>
        <a href="/venue/families-pets" class="self-start px-8 py-4 text-[11px] font-bold tracking-[0.22em] uppercase transition-all duration-200" style="border: 2px solid var(--color-brand-dark); color: var(--color-brand-dark);">
          Learn More
        </a>
      </div>
    </div>
  </section>


  <!-- ─── PRIVATE EVENTS CTA BAND ──────────────────────────────── -->
  <section class="relative overflow-hidden min-h-[600px] flex items-center">
    <img
      src="/images/venue/park-101-outdoor-rooftop-evening-crowd-ambiance-carlsbad.jpg"
      alt="Park 101 rooftop evening crowd — private events Carlsbad CA"
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="lazy"
    />
