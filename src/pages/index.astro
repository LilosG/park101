---
import Layout from '../layouts/Layout.astro';
import siteProfile from '../data/site-profile.json';

const { ordering, contact, hoursDisplay, stats } = siteProfile;
---

<Layout
  title="Park 101 | Rooftop Bar & Restaurant in Carlsbad Village CA"
  description="Multi-level rooftop bar and restaurant in Carlsbad Village, CA. BBQ, craft beer, cocktails, 20+ screens, game day headquarters, family and pet friendly. One block from the beach."
  transparentNav={true}
>

  <!-- ═══════════════════════════════════════════════════════
       §1  HERO
       Technique: absolute-positioned image inside overflow-hidden
       wrapper. Section itself has NO overflow-hidden so the stat
       bar fuses cleanly at the bottom edge.
  ═══════════════════════════════════════════════════════ -->
  <section class="relative min-h-hero flex flex-col justify-end">

    <!-- Image container — overflow-hidden here, NEVER on section -->
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/venue/park-101-outdoor-rooftop-string-lights-tropical-vibes-carlsbad.jpg"
        alt="Packed rooftop courtyard at Park 101 Carlsbad with string lights, tropical palms, and LED wall"
        class="w-full h-full object-cover scale-105"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        width="1920"
        height="1080"
      />
    </div>

    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/55 to-transparent"></div>

    <!-- Decorative vertical spine — right edge editorial texture -->
    <div class="absolute right-8 top-1/2 -translate-y-1/2 hidden xl:flex items-center" aria-hidden="true">
      <span class="font-display font-900 text-xs uppercase tracking-ultra text-brand-white/8 writing-vertical select-none">
        PRK&middot;101 &mdash; Carlsbad Village &mdash; Rooftop Bar &amp; Restaurant
      </span>
    </div>

    <!-- Content anchor — bottom left -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 pb-20 pt-48 w-full">
      <p class="font-display font-700 text-xs uppercase tracking-eyebrow text-brand-orange mb-5">
        Carlsbad Village, CA &mdash; One Block From the Beach
      </p>
      <h1 class="font-display font-900 uppercase leading-ultra text-brand-white mb-6 max-w-4xl text-hero">
        Where Coast<br />Meets Country
      </h1>
      <p class="font-editorial italic text-brand-white/70 mb-10 max-w-lg text-editorial leading-relaxed">
        North County&rsquo;s rooftop sports bar, BBQ, and game day headquarters.
        Two levels. Open air. All year.
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href={ordering.reservationsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-8 py-4 font-display font-700 text-sm uppercase tracking-cta border border-brand-white/50 text-brand-white hover:border-brand-orange hover:text-brand-orange transition-all duration-300"
        >
          Reserve a Table
        </a>
        <a
          href="/menu"
          class="inline-block px-8 py-4 font-display font-700 text-sm uppercase tracking-cta bg-brand-orange text-brand-white hover:bg-brand-orange-dark transition-colors duration-200"
        >
          View the Menu
        </a>
      </div>
    </div>

    <!-- Stat bar — fused to hero bottom, blends dark/glass -->
    <div class="relative z-10 w-full border-t border-brand-white/10 bg-brand-dark/80 backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-brand-white/10">
          {stats.map((stat) => (
            <div class="py-5 px-6 text-center">
              <p class="font-display font-900 text-2xl lg:text-3xl text-brand-white uppercase">{stat.value}</p>
              <p class="font-display font-600 text-xs uppercase tracking-label text-brand-white/40 mt-1">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §2  THE VENUE — Asymmetric Editorial
       Technique: CSS grid [3fr 2fr]. Main image has an
       absolutely-positioned offset secondary image that bleeds
       outside its container using translate-x / translate-y.
       Section is dark to contrast against the cream that follows.
  ═══════════════════════════════════════════════════════ -->
  <section class="relative bg-brand-dark-light">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-24 lg:py-32">
      <div class="grid lg:grid-cols-[3fr_2fr] gap-16 lg:gap-24 items-center">

        <!-- Image column — staggered editorial pair -->
        <div class="relative">
          <div class="overflow-hidden aspect-venue">
            <img
              src="/images/venue/park-101-rooftop-bar-lounge-venue-carlsbad.jpg"
              alt="Open rooftop deck at Park 101 Carlsbad Village with string lights and sweeping views"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
              loading="lazy"
              decoding="async"
              width="1200"
              height="900"
            />
          </div>
          <!-- Secondary staggered image — translate offset breaks the rectangle -->
          <div class="absolute -bottom-10 -right-6 w-2/5 aspect-square overflow-hidden border-4 border-brand-dark-light hidden lg:block translate-y-4">
            <img
              src="/images/venue/park-101-outdoor-family-friendly-gathering-carlsbad.jpg"
              alt="Guests at the outdoor patio at Park 101 Carlsbad"
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
              width="500"
              height="500"
            />
          </div>
        </div>

        <!-- Text column -->
        <div class="lg:pl-4 lg:pb-16">
          <p class="font-display font-700 text-xs uppercase tracking-eyebrow text-brand-orange mb-6">The Venue</p>
          <h2 class="font-display font-900 uppercase text-brand-white leading-ultra text-section-lg mb-6">
            Two Levels.<br />Open Air.<br />All Year.
          </h2>
          <p class="font-editorial italic text-brand-tan text-lg mb-10 leading-relaxed">
            Open-air rooftop with Pacific views. Covered courtyard with the biggest
            screen in North County. Fire pits, indoor bars, and communal tables.
          </p>
          <div class="flex flex-col gap-3 mb-10">
            {['Rooftop Deck & Ocean Views', 'Massive LED TV Wall', 'Fire Pits & Communal Tables', 'Dog-Friendly Patio'].map((feat) => (
              <div class="flex items-center gap-4">
                <span class="w-8 h-px bg-brand-orange flex-shrink-0"></span>
                <span class="font-display font-600 text-sm uppercase tracking-display text-brand-white/60">{feat}</span>
              </div>
            ))}
          </div>
          <div class="flex gap-4 flex-wrap">
            <a href="/venue/rooftop" class="inline-block px-6 py-3 font-display font-700 text-sm uppercase tracking-cta border border-brand-white/25 text-brand-white hover:border-brand-orange hover:text-brand-orange transition-all duration-300">
              See the Rooftop
            </a>
            <a href="/private-events" class="inline-block font-display font-700 text-sm uppercase tracking-cta text-brand-tan hover:text-brand-white transition-colors duration-200 self-center">
              Private Events &rarr;
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §3  FOOD + BAR — Magazine Split
       Technique: CSS grid [3fr 2fr] at full section height.
       Left column = image fills 100% height via object-cover.
       Right column = dark editorial panel with 2×2 drink grid.
       Neither column has overflow-hidden on the section wrapper.
  ═══════════════════════════════════════════════════════ -->
  <section class="relative bg-brand-dark lg:grid lg:grid-cols-[3fr_2fr]" style="min-height: 80vh;">

    <!-- Left: full-height food image -->
    <div class="overflow-hidden min-h-panel lg:min-h-0">
      <img
        src="/images/food/park-101-prk-food-spread-02-carlsbad.jpg"
        alt="BBQ spread at Park 101 — smoked tri-tip, ribs, tacos, loaded fries, and bar bites"
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
        loading="lazy"
        decoding="async"
        width="1200"
        height="1600"
      />
    </div>

    <!-- Right: editorial panel -->
    <div class="bg-brand-dark flex flex-col justify-center px-10 lg:px-14 py-16 lg:py-24">
      <p class="font-display font-700 text-xs uppercase tracking-eyebrow text-brand-orange mb-6">The Kitchen &amp; Bar</p>
      <h2 class="font-display font-900 uppercase text-brand-white leading-ultra text-section-lg mb-6">
        Real BBQ.<br />Cold Drinks.
      </h2>
      <p class="font-editorial italic text-brand-white/55 text-lg mb-10 leading-relaxed">
        Low-and-slow brisket, St.&nbsp;Louis ribs, and smoked tri-tip alongside a
        full craft bar and cocktails built for the California sun.
      </p>

      <!-- 2×2 drink image grid -->
      <div class="grid grid-cols-2 gap-2 mb-10">
        {[
          { src: '/images/drinks/park-101-pink-cocktail-flower-garnish-02-carlsbad.jpg',       alt: 'Signature pink cocktail at Park 101' },
          { src: '/images/drinks/park-101-spiced-rim-citrus-cocktail-carlsbad.jpg',            alt: 'Spiced rim citrus cocktail at Park 101' },
          { src: '/images/brunch/park-101-brunch-dsc08255-carlsbad.jpg',                      alt: 'Bloody Mary with smoked rib at Park 101 brunch' },
          { src: '/images/drinks/park-101-tropical-pink-cocktail-flower-garnish-carlsbad.jpg', alt: 'Tropical cocktail at Park 101' },
        ].map(({ src, alt }) => (
          <div class="overflow-hidden aspect-square">
            <img
              src={src}
              alt={alt}
              class="w-full h-full object-cover hover:scale-110 transition-transform duration-500"
              loading="lazy"
              decoding="async"
              width="400"
              height="400"
            />
          </div>
        ))}
      </div>

      <a href="/menu" class="inline-block self-start px-8 py-4 font-display font-700 text-sm uppercase tracking-cta bg-brand-orange text-brand-white hover:bg-brand-orange-dark transition-colors duration-200">
        Full Menu
      </a>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §4  GAME DAY — Full-Bleed Cinematic
       Technique: gradient covers left 65%, right 35% of image
       is fully unobscured — cinematic, not a text-over-image box.
  ═══════════════════════════════════════════════════════ -->
  <section class="relative min-h-cinematic flex flex-col justify-end">
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/venue/park-101-outdoor-rooftop-sports-bar-lounge-carlsbad.jpg"
        alt="Guests watching NFL on the LED wall at Park 101 game day headquarters Carlsbad"
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
        width="1920"
        height="1080"
      />
    </div>
    <!-- Directional gradient — dark left, clear right -->
    <div class="absolute inset-0 bg-gradient-to-r from-brand-dark/95 via-brand-dark/60 to-transparent"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-10 pb-20 pt-32 w-full">
      <div class="max-w-xl">
        <p class="font-display font-700 text-xs uppercase tracking-eyebrow text-brand-orange mb-5">Game Day Headquarters</p>
        <h2 class="font-display font-900 uppercase text-brand-white leading-ultra text-section-xl mb-6">
          North County&rsquo;s<br />Outdoor Stadium.
        </h2>
        <p class="font-editorial italic text-brand-white/65 text-lg mb-10 leading-relaxed">
          NFL Sundays. Padres games. UFC fight nights.
          Massive LED TV wall, 20+ screens, and a crowd that brings the energy every time.
        </p>
        <div class="flex gap-4 flex-wrap">
          <a href="/venue/sports" class="inline-block px-7 py-4 font-display font-700 text-sm uppercase tracking-cta border border-brand-white/40 text-brand-white hover:border-brand-orange hover:text-brand-orange transition-all duration-300">
            Game Day Info
          </a>
          <a href={ordering.reservationsUrl} target="_blank" rel="noopener noreferrer" class="inline-block px-7 py-4 font-display font-700 text-sm uppercase tracking-cta bg-brand-orange text-brand-white hover:bg-brand-orange-dark transition-colors duration-200">
            Reserve Your Spot
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §5  WEEKLY SPECIALS — Orange Brand Band
       Intentional tonal break — only orange section on page.
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-brand-orange">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-16 lg:py-20">
      <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-10">
        <div class="flex-shrink-0">
          <p class="font-display font-700 text-xs uppercase tracking-eyebrow text-brand-white/55 mb-4">Every Week</p>
          <h2 class="font-display font-900 uppercase text-brand-white leading-ultra text-section">
            Specials Worth<br />Showing Up For
          </h2>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 flex-1 lg:max-w-2xl">
          {[
            { day: 'Monday',     copy: '50% Off Drinks for Carlsbad Residents' },
            { day: 'Tuesday',    copy: 'Taco Tuesday + Trivia Night at 7pm' },
            { day: 'Wednesday',  copy: 'Bingo Night — $16 Beer & Burger' },
            { day: 'Thursday',   copy: 'Wing Night — $1.25/Wing, 6 Min.' },
            { day: 'Friday',     copy: 'Dukes N Boots — Line Dancing Bi-Weekly' },
            { day: 'Happy Hour', copy: 'Mon–Fri 3–6 PM Drinks & Food' },
          ].map(({ day, copy }) => (
            <div class="bg-brand-dark/20 px-4 py-4">
              <p class="font-display font-800 text-sm uppercase tracking-display text-brand-white">{day}</p>
              <p class="font-body text-xs text-brand-white/75 mt-1.5 leading-snug">{copy}</p>
            </div>
          ))}
        </div>
        <a href="/weekly-specials" class="flex-shrink-0 inline-block px-7 py-4 font-display font-700 text-sm uppercase tracking-cta border-2 border-brand-white text-brand-white hover:bg-brand-white hover:text-brand-orange transition-all duration-300">
          Full Specials
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §6  LIVE MUSIC + BRUNCH — Two Cinematic Panels
       Technique: CSS grid 50/50. Each panel is a self-contained
       cinematic unit — full-bleed image + gradient + content.
       NOT a stacked block. The two panels read as one section.
  ═══════════════════════════════════════════════════════ -->
  <section class="grid lg:grid-cols-2" style="min-height: 65vh;">

    <!-- Panel A: Live Music -->
    <div class="relative flex flex-col justify-end min-h-panel lg:min-h-0">
      <div class="absolute inset-0 overflow-hidden">
        <img
          src="/images/venue/park-101-outdoor-venue-string-lights-live-music-carlsbad.jpg"
          alt="Live country band performing at Park 101 Carlsbad under string lights"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
          decoding="async"
          width="960"
          height="1080"
        />
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/45 to-transparent"></div>
      <div class="relative z-10 px-8 py-10">
        <p class="font-display font-700 text-xs uppercase tracking-eyebrow text-brand-orange mb-3">Every Week</p>
        <h2 class="font-display font-900 uppercase text-brand-white leading-ultra text-panel mb-4">
          Live Music.<br />Every Week.
        </h2>
        <p class="font-body text-sm text-brand-white/65 mb-7 max-w-xs leading-relaxed">
          Live bands, themed nights, and events that pack the courtyard. PRK 101 is where North County comes out to play.
        </p>
        <a href="/venue/live-events" class="inline-block px-6 py-3 font-display font-700 text-sm uppercase tracking-cta border border-brand-white/40 text-brand-white hover:border-brand-orange hover:text-brand-orange transition-all duration-300">
          See What&rsquo;s On
        </a>
      </div>
    </div>

    <!-- Panel B: Brunch — reversed gradient direction for visual distinction -->
    <div class="relative flex flex-col justify-end min-h-panel lg:min-h-0">
      <div class="absolute inset-0 overflow-hidden">
        <img
          src="/images/brunch/park-101-brunch-dsc03776-carlsbad.jpg"
          alt="Rooftop brunch at Park 101 — tri-tip chilaquiles with fried egg and fresh herbs"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
          decoding="async"
          width="960"
          height="1080"
        />
      </div>
      <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/95 via-brand-dark/35 to-transparent"></div>
      <div class="relative z-10 px-8 py-10">
        <p class="font-display font-700 text-xs uppercase tracking-eyebrow text-brand-orange mb-3">Sat &amp; Sun</p>
        <h2 class="font-display font-900 uppercase text-brand-white leading-ultra text-panel mb-4">
          Brunch on<br />the Rooftop.
        </h2>
        <p class="font-body text-sm text-brand-white/65 mb-7 max-w-xs leading-relaxed">
          Chilaquiles, chicken &amp; waffles, burritos, and a Bloody Mary with a smoked rib on top.
        </p>
        <a href="/menu" class="inline-block px-6 py-3 font-display font-700 text-sm uppercase tracking-cta border border-brand-white/40 text-brand-white hover:border-brand-orange hover:text-brand-orange transition-all duration-300">
          Brunch Menu
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §7  PRIVATE EVENTS — Full-Bleed with Editorial Frame
       Technique: decorative corner bracket elements (absolute
       positioned border fragments) create an editorial frame
       without any generic card/container structure.
  ═══════════════════════════════════════════════════════ -->
  <section class="relative min-h-events flex flex-col justify-center items-center text-center">
    <div class="absolute inset-0 overflow-hidden">
      <img
        src="/images/venue/park-101-outdoor-rooftop-bar-evening-crowd-carlsbad.jpg"
        alt="Evening event crowd at Park 101 Carlsbad rooftop"
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
        width="1920"
        height="1080"
      />
    </div>
    <div class="absolute inset-0 bg-brand-dark/78"></div>

    <!-- Decorative corner frame — editorial micro-detail -->
    <div class="absolute inset-10 pointer-events-none hidden lg:block" aria-hidden="true">
      <span class="absolute top-0 left-0 w-16 h-16 border-t border-l border-brand-orange/35"></span>
      <span class="absolute top-0 right-0 w-16 h-16 border-t border-r border-brand-orange/35"></span>
      <span class="absolute bottom-0 left-0 w-16 h-16 border-b border-l border-brand-orange/35"></span>
      <span class="absolute bottom-0 right-0 w-16 h-16 border-b border-r border-brand-orange/35"></span>
    </div>

    <div class="relative z-10 px-8 py-24 max-w-3xl">
      <p class="font-display font-700 text-xs uppercase tracking-ultra text-brand-orange mb-6">Private Events</p>
      <h2 class="font-display font-900 uppercase text-brand-white leading-ultra text-section-xl mb-8">
        Your Event.<br />Our Venue.
      </h2>
      <p class="font-editorial italic text-brand-white/65 text-xl mb-10 max-w-xl mx-auto leading-relaxed">
        Birthdays, corporate buyouts, game day parties, rehearsal dinners &mdash;
        Carlsbad&rsquo;s best outdoor event space. One block from the beach.
      </p>
      <a href="/private-events" class="inline-block px-10 py-4 font-display font-700 text-sm uppercase tracking-cta border border-brand-orange text-brand-orange hover:bg-brand-orange hover:text-brand-white transition-all duration-300">
        Plan Your Event
      </a>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       §8  INFO BAND — Compact Dark
       Hours, address, and CTAs. Tonal resolution of the page.
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-brand-dark border-t border-brand-dark-light">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-16 lg:py-20">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">

        <!-- Address -->
        <div>
          <p class="font-display font-700 text-xs uppercase tracking-eyebrow text-brand-orange mb-5">Find Us</p>
          <p class="font-display font-700 text-lg uppercase tracking-display text-brand-white mb-1">
            {contact.address.street}
          </p>
          <p class="font-display font-600 text-sm uppercase tracking-display text-brand-white/40 mb-6">
            {contact.address.city}, {contact.address.state} {contact.address.zip}
          </p>
          <a
            href={contact.googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="font-display font-700 text-xs uppercase tracking-cta text-brand-orange hover:text-brand-orange-light transition-colors duration-200"
          >
            Get Directions &rarr;
          </a>
        </div>

        <!-- Hours -->
        <div>
          <p class="font-display font-700 text-xs uppercase tracking-eyebrow text-brand-orange mb-5">Hours</p>
          <div class="flex flex-col gap-2.5">
            {hoursDisplay.map((h) => (
              <div class="flex justify-between gap-4">
                <span class="font-display font-600 text-sm uppercase tracking-wider text-brand-white/40">{h.days}</span>
                <span class="font-display font-700 text-sm uppercase tracking-wider text-brand-white">{h.hours}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-col gap-4">
          <p class="font-display font-700 text-xs uppercase tracking-eyebrow text-brand-orange mb-1">Reserve &amp; Order</p>
          <a
            href={ordering.reservationsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full py-4 text-center font-display font-700 text-sm uppercase tracking-cta bg-brand-orange text-brand-white hover:bg-brand-orange-dark transition-colors duration-200"
          >
            Reserve a Table
          </a>
          <a
            href={ordering.toastUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-full py-4 text-center font-display font-700 text-sm uppercase tracking-cta border border-brand-white/20 text-brand-white hover:border-brand-orange hover:text-brand-orange transition-all duration-300"
          >
            Order Takeout
          </a>
        </div>

      </div>
    </div>
  </section>

</Layout>
