---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import { Image } from 'astro:assets';

import stLouisRibs from '../assets/food/park-101-st-louis-ribs-carlsbad.jpg';
import smokedBrisket from '../assets/food/park-101-bbq-brisket-platter-sides-carlsbad.jpg';
import shrimpTacosImg from '../assets/food/park-101-shrimp-tacos-carlsbad.jpg';
import theWesternBurger from '../assets/food/park-101-the-western-carlsbad.jpg';
import smokedTriTipPhillyImg from '../assets/food/park-101-smoked-tri-tip-philly-carlsbad.jpg';
import triTipTacosImg from '../assets/food/park-101-tri-tip-tacos-carlsbad.jpg';
import loadedBbqMac from '../assets/food/park-101-loaded-bbq-mac-06-carlsbad.jpg';

import rodeoTowerPrk101 from '../assets/drinks/park-101-rodeo-tower-prk101-carlsbad.jpg';
import dontMessWithMe from '../assets/drinks/park-101-dont-mess-with-me-cocktail-carlsbad.jpg';
import gunPowderLead from '../assets/drinks/park-101-gun-powder-lead-cocktail-carlsbad.jpg';
import talkingIrons from '../assets/drinks/park-101-talking-irons-cocktail-carlsbad.jpg';

import heroImage from '../assets/venue/park-101-outdoor-rooftop-string-lights-tropical-vibes-carlsbad.jpg';
import firePitPatio from '../assets/venue/park-101-outdoor-fire-pit-patio-venue-carlsbad.jpg';
import padresGameDay from '../assets/venue/park-101-padres-game-day-packed-venue-carlsbad.jpg';
import liveMusicCountry from '../assets/venue/park-101-live-music-country-wide-carlsbad.jpg';
import familiesKidsGameDay from '../assets/venue/park-101-families-kids-game-day-carlsbad.jpg';
import rooftopEveningGroup from '../assets/venue/park-101-rooftop-evening-group-carlsbad.jpg';

import brunchChilaquiles from '../assets/brunch/park-101-brunch-chilaquiles-tri-tip-carlsbad.jpg';

const siteProfile = (await getEntry('siteSettings', 'site-settings'))!.data;
const page = (await getCollection('home'))[0].data;
const blockText = (value: string) => `\n${value}\n`;
const blockHtml = (value: string) => `\n${value.replaceAll('<br />', '<br>')}\n`;
const inlineText = (value: string) => ` ${value} `;
const homeEyebrowHtml = (value: string) => ` ${value}\n`;
const venueSection = page.sections.venue;
const sportsSection = page.sections.sports;
const foodSection = page.sections.food;
const smokehouseSection = page.sections.smokehouse;
const drinksSection = page.sections.drinks;
const eventsSection = page.sections.events;
const brunchSection = page.sections.brunch;
const familiesSection = page.sections.families;
const privateEventsSection = page.sections.privateEvents;

const foodItems = [
  {
    src: stLouisRibs,
    alt: 'St. Louis ribs with BBQ sauce and pickles at Park 101 Carlsbad',
    name: 'St. Louis Ribs',
  },
  {
    src: smokedBrisket,
    alt: 'Sliced smoked brisket platter with sauce at Park 101 Carlsbad',
    name: 'Smoked Brisket',
  },
  {
    src: shrimpTacosImg,
    alt: 'Shrimp tacos with chipotle sauce and lime at Park 101 Carlsbad',
    name: 'Shrimp Tacos',
  },
  {
    src: theWesternBurger,
    alt: 'Loaded bacon cheeseburger with fries at Park 101 Carlsbad',
    name: 'The Western Burger',
  },
  {
    src: smokedTriTipPhillyImg,
    alt: 'Smoked tri-tip Philly cheesesteak sandwich at Park 101 Carlsbad',
    name: 'Smoked Tri-Tip Philly',
  },
  {
    src: triTipTacosImg,
    alt: 'Tri-tip tacos with chimichurri and cotija at Park 101 Carlsbad',
    name: 'Tri-Tip Tacos',
  },
];

const drinkItems = [
  {
    src: rodeoTowerPrk101,
    alt: 'Signature Rodeo Tower cocktail display at Park 101 Carlsbad with PRK 101 sign',
  },
  {
    src: dontMessWithMe,
    alt: "Don't At Me cocktail at Park 101 Carlsbad",
  },
  {
    src: gunPowderLead,
    alt: 'Gun Powder and Lead cocktail with fresh mint at Park 101 Carlsbad',
  },
  {
    src: talkingIrons,
    alt: 'Talking Irons whiskey cocktail on the rooftop at Park 101 Carlsbad',
  },
];
---

<Layout
  title={page.seo.title}
  description={page.seo.description}
  ogImage={page.seo.ogImage}
  transparentNav={true}
>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-screen w-full bg-brand-dark flex flex-col justify-between overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImage}
        alt="Park 101 packed outdoor courtyard with string lights, palm trees, and multi-level venue in Carlsbad Village"
        class="w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
        width={1920}
      />
      <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/55 to-brand-dark/10"></div>
    </div>

    <div class="h-20 shrink-0"></div>

    <div class="relative z-10 max-w-7xl w-full mx-auto px-6 sm:px-8 lg:px-12 pb-8">
      <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4"><Fragment set:html={homeEyebrowHtml(page.hero.eyebrow)} /></span>
      <h1 class="font-display font-bold text-hero text-brand-white uppercase leading-ultra tracking-tight max-w-4xl mb-3">{blockText(page.hero.heading)}</h1>
      {page.hero.subheading && (
        <p class="font-display font-bold text-panel text-brand-orange uppercase tracking-tight leading-snug max-w-2xl mb-6">{blockText(page.hero.subheading)}</p>
      )}
      {page.hero.body && (
        <p class="font-body font-light text-brand-cream/75 text-lg sm:text-xl max-w-lg mb-8 leading-relaxed">{inlineText(page.hero.body)}</p>
      )}
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={siteProfile.ordering.reservationsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
        >
          Reserve a Table
        </a>
        <a
          href="/venue"
          class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
        >
          Explore the Venue
        </a>
      </div>
    </div>

    <!-- Stat Bar -->
    <div class="relative z-10 w-full bg-brand-dark/80 backdrop-blur-sm border-t border-brand-white/10 py-5 sm:py-6">
      <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-y-4 gap-x-4 md:divide-x divide-brand-white/10 text-center">
          {siteProfile.stats.map((stat: { label: string; value: string }) => (
            <div class="px-4">
              <span class="block font-display font-bold text-xl sm:text-2xl text-brand-white uppercase tracking-wide leading-tight">{stat.value}</span>
              <span class="block font-body text-[10px] sm:text-xs tracking-stat uppercase text-brand-orange mt-1">{stat.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── THE VENUE ─────────────────────────────────────────── -->
  {venueSection && (
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[700px]">
      <div class="relative lg:col-span-7 min-h-[400px] lg:min-h-full overflow-hidden">
        <Image
          src={firePitPatio}
          alt="Park 101 full outdoor courtyard at dusk with fire pit seating, LED screen, tables, and multi-level venue"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
          width={1400}
        />
      </div>
      <div class="lg:col-span-5 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{inlineText(venueSection.eyebrow)}</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6"><Fragment set:html={blockHtml(venueSection.heading)} /></h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          {venueSection.body && (
            <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">{blockText(venueSection.body)}</p>
          )}
          <a
            href="/venue"
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            See All Spaces
          </a>
        </div>
      </div>
    </div>
  </section>
  )}

  <!-- ── SPORTS / GAME DAY ────────────────────────────────── -->
  {sportsSection && (
  <section class="relative bg-brand-dark">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[700px]">
      <div class="lg:col-span-5 order-2 lg:order-1 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-dark">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{inlineText(sportsSection.eyebrow)}</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6"><Fragment set:html={blockHtml(sportsSection.heading)} /></h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-cream/70 text-base sm:text-lg leading-relaxed mb-8">
            {siteProfile.venue.sports.description}
          </p>
          <div class="flex flex-wrap gap-x-4 gap-y-2 mb-8 pb-8 border-b border-brand-white/10">
            {siteProfile.venue.sports.features.map((feature: string) => (
              <span class="font-display font-bold text-xs uppercase tracking-feature text-brand-white">{feature}</span>
            ))}
          </div>
          <a
            href="/events"
            class="inline-block px-6 py-3.5 border border-brand-white hover:bg-brand-white hover:text-brand-dark text-brand-white font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            View the Lineup
          </a>
        </div>
      </div>
      <div class="relative lg:col-span-7 order-1 lg:order-2 min-h-[400px] lg:min-h-full overflow-hidden">
        <Image
          src={padresGameDay}
          alt="Packed crowd at Park 101 Carlsbad during a San Diego Padres game with the Home of the San Diego Padres banner and LED wall"
          class="absolute inset-0 w-full h-full object-cover object-[50%_35%]"
          loading="lazy"
          width={1400}
        />
      </div>
    </div>
  </section>
  )}

  <!-- ── FOOD GRID ─────────────────────────────────────────── -->
  {foodSection && (
  <section class="relative bg-brand-cream py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-14">
        <span class="block font-body text-xs font-bold tracking-eyebrow-wide uppercase text-brand-orange mb-3">{blockText(foodSection.eyebrow)}</span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase tracking-tight">{blockText(foodSection.heading)}</h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5">
        {foodItems.map((item) => (
          <div class="group relative overflow-hidden bg-brand-dark aspect-[4/3]">
            <Image
              src={item.src}
              alt={item.alt}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
              loading="lazy"
              width={800}
            />
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/90 via-brand-dark/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-5">
              <span class="font-display font-bold text-base uppercase tracking-wider text-brand-white">{item.name}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href="/menu"
          class="inline-block px-8 py-4 bg-brand-dark hover:bg-brand-dark/80 text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200"
        >
          View Full Menu
        </a>
      </div>
    </div>
  </section>
  )}

  <!-- ── BBQ FEATURE ──────────────────────────────────────── -->
  {smokehouseSection && (
  <section class="relative bg-brand-dark">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[650px]">
      <div class="relative lg:col-span-6 min-h-[400px] lg:min-h-full overflow-hidden">
        <Image
          src={loadedBbqMac}
          alt="Three BBQ platters of pulled pork, St. Louis ribs, and sliced brisket from the Park 101 smokehouse"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
          width={1400}
        />
      </div>
      <div class="lg:col-span-6 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-dark">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(smokehouseSection.eyebrow)}</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6"><Fragment set:html={blockHtml(smokehouseSection.heading)} /></h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          {smokehouseSection.body && (
            <p class="font-body font-light text-brand-cream/70 text-base sm:text-lg leading-relaxed mb-8">{blockText(smokehouseSection.body)}</p>
          )}
          <a
            href="/menu"
            class="inline-block px-6 py-3.5 border border-brand-white hover:bg-brand-white hover:text-brand-dark text-brand-white font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            Full Smokehouse Menu
          </a>
        </div>
      </div>
    </div>
  </section>
  )}

  <!-- ── DRINKS ────────────────────────────────────────────── -->
  {drinksSection && (
  <section class="relative bg-brand-steel py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-xl mb-12">
        <span class="block font-body text-xs font-bold tracking-eyebrow-wide uppercase text-brand-orange mb-3">{blockText(drinksSection.eyebrow)}</span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight leading-display"><Fragment set:html={blockHtml(drinksSection.heading)} /></h2>
        <div class="w-12 h-[2px] bg-brand-orange mt-5 mb-5"></div>
        {drinksSection.body && (
          <p class="font-body font-light text-brand-cream/70 text-base sm:text-lg max-w-lg leading-relaxed"><Fragment set:html={blockText(drinksSection.body)} /></p>
        )}
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">
        {drinkItems.map((item) => (
          <div class="relative overflow-hidden bg-brand-dark aspect-square">
            <Image
              src={item.src}
              alt={item.alt}
              class="absolute inset-0 w-full h-full object-cover"
              loading="lazy"
              width={800}
            />
          </div>
        ))}
      </div>
    </div>
  </section>
  )}

  <!-- ── NORTH COUNTY LINEUP ───────────────────────────────── -->
  {eventsSection && (
  <section class="relative min-h-[520px] flex items-center justify-center text-center px-6 py-24 overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={liveMusicCountry}
        alt="Country guitarist performing live at Park 101 Carlsbad with the LED screen and crowd behind him"
        class="w-full h-full object-cover object-[50%_62%]"
        loading="lazy"
        width={1920}
      />
      <div class="absolute inset-0 bg-brand-dark/60"></div>
    </div>
    <div class="relative z-10 max-w-2xl w-full mx-auto">
      <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">{inlineText(eventsSection.eyebrow)}</span>
      <h2 class="font-display font-bold text-5xl sm:text-6xl text-brand-white uppercase tracking-tight leading-ultra mb-6"><Fragment set:html={blockHtml(eventsSection.heading)} /></h2>
      {eventsSection.body && (
        <p class="font-body font-light text-brand-cream/80 text-base sm:text-lg leading-relaxed mb-8 max-w-lg mx-auto"><Fragment set:html={blockText(eventsSection.body)} /></p>
      )}
      <a
        href="/events"
        class="inline-block px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200"
      >
        View the Lineup
      </a>
    </div>
  </section>
  )}

  <!-- ── BRUNCH ─────────────────────────────────────────────── -->
  {brunchSection && (
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[700px]">
      <div class="lg:col-span-5 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(brunchSection.eyebrow)}</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">{blockText(brunchSection.heading)}</h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          {brunchSection.body && (
            <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">{blockText(brunchSection.body)}</p>
          )}
          <a
            href="/brunch"
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            See the Brunch Menu
          </a>
        </div>
      </div>
      <div class="relative lg:col-span-7 min-h-[400px] lg:min-h-full overflow-hidden">
        <Image
          src={brunchChilaquiles}
          alt="Smoked tri-tip chilaquiles bowl with a fried egg, cotija cheese, pickled onions, and jalapeños at Park 101 brunch"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
          width={1400}
        />
      </div>
    </div>
  </section>
  )}

  <!-- ── FAMILIES & COMMUNITY ─────────────────────────────── -->
  {familiesSection && (
  <section class="relative bg-brand-tan">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[650px]">
      <div class="relative lg:col-span-6 min-h-[400px] lg:min-h-full overflow-hidden">
        <Image
          src={familiesKidsGameDay}
          alt="Families and kids in Padres jerseys enjoying game day together at Park 101 Carlsbad"
          class="absolute inset-0 w-full h-full object-cover object-[50%_75%]"
          loading="lazy"
          width={1400}
        />
      </div>
      <div class="lg:col-span-6 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-tan">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{inlineText(familiesSection.eyebrow)}</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6"><Fragment set:html={blockHtml(familiesSection.heading)} /></h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">
            {siteProfile.venue.familiesPets.description}
          </p>
          <div class="flex flex-wrap gap-2 mb-8">
            {siteProfile.venue.familiesPets.features.map((feature: string) => (
              <span class="px-3 py-1.5 border border-brand-dark/25 font-display font-bold text-xs uppercase tracking-wide text-brand-dark">{feature}</span>
            ))}
          </div>
          <a
            href="/venue"
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            Plan Your Visit
          </a>
        </div>
      </div>
    </div>
  </section>
  )}

  <!-- ── PRIVATE EVENTS ────────────────────────────────────── -->
  {privateEventsSection && (
  <section class="relative min-h-[500px] flex items-center justify-center text-center px-6 py-24 overflow-hidden">
    <div class="absolute inset-0">
      <Image
        src={rooftopEveningGroup}
        alt="Evening group gathering on the rooftop at Park 101 Carlsbad with string lights and open-air venue"
        class="w-full h-full object-cover object-center"
        loading="lazy"
        width={1920}
      />
      <div class="absolute inset-0 bg-brand-dark/60"></div>
    </div>
    <div class="relative z-10 max-w-2xl w-full mx-auto">
      <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">{blockText(privateEventsSection.eyebrow)}</span>
      <h2 class="font-display font-bold text-5xl sm:text-6xl text-brand-white uppercase tracking-tight leading-ultra mb-6"><Fragment set:html={blockHtml(privateEventsSection.heading)} /></h2>
      {privateEventsSection.body && (
        <p class="font-body font-light text-brand-cream/80 text-base sm:text-lg leading-relaxed mb-8 max-w-lg mx-auto"><Fragment set:html={blockText(privateEventsSection.body)} /></p>
      )}
      <a
        href="/private-events"
        class="inline-block px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200"
      >
        Inquire About Events
      </a>
    </div>
  </section>
  )}

  <!-- ── BOTTOM INFO BAR ───────────────────────────────────── -->
  <section class="bg-brand-dark border-t border-brand-white/10 py-10 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center justify-between gap-8 text-center lg:text-left">
      <div class="flex flex-col md:flex-row items-center lg:items-start gap-6 md:gap-10">
        <div>
          <span class="block font-display font-bold text-brand-orange text-[10px] tracking-widest uppercase mb-1">Address</span>
          <a
            href={siteProfile.contact.googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-sm text-brand-cream/80 hover:text-brand-orange transition-colors duration-150"
          >
            {siteProfile.contact.address.full}
          </a>
        </div>
        <div>
          <span class="block font-display font-bold text-brand-orange text-[10px] tracking-widest uppercase mb-1">Phone</span>
          <a
            href={`tel:${siteProfile.contact.phoneDial}`}
            class="font-body text-sm text-brand-cream/80 hover:text-brand-orange transition-colors duration-150"
          >
            {siteProfile.contact.phone}
          </a>
        </div>
        <div>
          <span class="block font-display font-bold text-brand-orange text-[10px] tracking-widest uppercase mb-1">Hours</span>
          <p class="font-body text-sm text-brand-cream/80">
            Open Daily from {siteProfile.hours.monday.open}
          </p>
        </div>
      </div>
      <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto flex-shrink-0">
        <a
          href={siteProfile.ordering.toastUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 border border-brand-white/40 hover:border-brand-orange hover:text-brand-orange text-brand-white/70 font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200 text-center whitespace-nowrap"
        >
          Order Takeout
        </a>
        <a
          href={siteProfile.ordering.reservationsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-6 py-3 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-xs transition-colors duration-200 text-center whitespace-nowrap"
        >
          Reserve a Table
        </a>
      </div>
    </div>
  </section>

</Layout>
