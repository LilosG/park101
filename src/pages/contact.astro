---
import Layout from '../layouts/Layout.astro';
import siteProfile from '../data/site-profile.json';

const pageTitle = 'Contact | PRK 101 Carlsbad';
const pageDescription = `Visit Park 101 at ${siteProfile.contact.address.full}. Hours, directions, and contact info.`;

const mapQuery = encodeURIComponent(siteProfile.contact.address.full);

// hours are stored as { monday: {open, close}, ... } — format properly,
// don't interpolate the nested object directly
const hoursList = Object.entries(
  siteProfile.hours as Record<string, { open: string; close: string }>
).map(([day, time]) => ({
  label: day.charAt(0).toUpperCase() + day.slice(1),
  time: `${time.open} – ${time.close}`,
}));

const hasEmail = Boolean(siteProfile.contact.email);
---

<Layout title={pageTitle} description={pageDescription} ogImage={siteProfile.seo.ogImage} transparentNav={true}>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-[600px] bg-brand-dark flex flex-col overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/venue/park-101-outdoor-rooftop-bar-evening-crowd-carlsbad.jpg"
        alt="Park 101 rooftop at dusk in Carlsbad Village"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-brand-dark/65"></div>
    </div>
    <div class="h-20 shrink-0"></div>
    <div class="relative z-10 flex-1 flex items-center justify-center px-6 sm:px-8 lg:px-12 pb-16">
      <div class="max-w-2xl mx-auto text-center">
        <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">
          Get In Touch
        </span>
        <h1 class="font-display font-bold text-section-xl text-brand-white uppercase leading-ultra tracking-tight mb-6">
          Find Us
        </h1>
        <p class="font-body font-light text-brand-cream/80 text-lg leading-relaxed mb-8 max-w-xl mx-auto">
          One block from the beach in Carlsbad Village.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={siteProfile.ordering.reservationsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
          >
            Reserve a Table
          </a>
          <a
            href={`tel:${siteProfile.contact.phone}`}
            class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
          >
            Call Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── INFO + MAP ───────────────────────────────────────── -->
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-2 items-stretch min-h-[550px]">
      <div class="flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0 w-full">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            Visit Us
          </span>
          <h2 class="font-display font-bold text-3xl text-brand-dark uppercase leading-display tracking-tight mb-4">
            Carlsbad Village
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-10"></div>

          <div class="space-y-10">
            <div>
              <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-2">
                Address
              </span>
              <a
                href={`https://maps.google.com/?q=${mapQuery}`}
                target="_blank"
                rel="noopener noreferrer"
                class="font-display font-bold text-2xl text-brand-dark hover:text-brand-orange transition-colors duration-200"
              >
                {siteProfile.contact.address.full}
              </a>
              <p class="font-body text-brand-dark/60 text-sm mt-1">{siteProfile.contact.neighborhood}, Carlsbad, CA</p>
            </div>

            <div>
              <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-2">
                Phone
              </span>
              <a
                href={`tel:${siteProfile.contact.phone}`}
                class="font-display font-bold text-2xl text-brand-dark hover:text-brand-orange transition-colors duration-200"
              >
                {siteProfile.contact.phone}
              </a>
            </div>

            {hasEmail && (
              <div>
                <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-2">
                  Email
                </span>
                <a
                  href={`mailto:${siteProfile.contact.email}`}
                  class="font-display font-bold text-2xl text-brand-dark hover:text-brand-orange transition-colors duration-200 break-all"
                >
                  {siteProfile.contact.email}
                </a>
              </div>
            )}

            <div>
              <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
                Hours
              </span>
              <ul class="space-y-1">
                {hoursList.map((entry) => (
                  <li class="flex justify-between font-body text-brand-dark/80 text-sm max-w-xs">
                    <span class="font-bold">{entry.label}</span>
                    <span>{entry.time}</span>
                  </li>
                ))}
              </ul>
            </div>

            <a
              href={siteProfile.ordering.reservationsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200"
            >
              Reserve a Table
            </a>
          </div>
        </div>
      </div>

      <div class="relative min-h-[400px] lg:min-h-full overflow-hidden p-4 lg:p-6 bg-brand-dark">
        <div class="relative w-full h-full min-h-[380px] overflow-hidden border border-brand-orange/30">
          <iframe
            src={`https://maps.google.com/maps?q=${mapQuery}&output=embed`}
            class="absolute inset-0 w-full h-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Park 101 location map"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

</Layout>
