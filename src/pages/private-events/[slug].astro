---
import Layout from '../../layouts/Layout.astro';
import siteProfile from '../../data/site-profile.json';
import { privateEventImages } from '../../data/private-events-images';

export function getStaticPaths() {
  return siteProfile.privateEvents.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const image = privateEventImages[event.slug];

const pageTitle = `${event.name} Venue in Carlsbad | PRK 101`;
const pageDescription = `${event.description} ${event.capacity} in Carlsbad Village.`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteProfile.url },
    { '@type': 'ListItem', position: 2, name: 'Private Events', item: `${siteProfile.url}/private-events` },
    { '@type': 'ListItem', position: 3, name: event.name, item: `${siteProfile.url}/private-events/${event.slug}` },
  ],
};
---

<Layout title={pageTitle} description={pageDescription} ogImage={siteProfile.seo.ogImage}>

  <!-- ── BREADCRUMB ───────────────────────────────────────── -->
  <nav aria-label="Breadcrumb" class="bg-brand-cream pt-28 pb-4 px-6 sm:px-8 lg:px-12">
    <ol class="max-w-7xl mx-auto flex items-center gap-2 font-body text-xs text-brand-dark/60">
      <li><a href="/" class="hover:text-brand-orange transition-colors duration-150">Home</a></li>
      <li>/</li>
      <li><a href="/private-events" class="hover:text-brand-orange transition-colors duration-150">Private Events</a></li>
      <li>/</li>
      <li class="text-brand-dark font-medium">{event.name}</li>
    </ol>
  </nav>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative bg-brand-dark overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[550px]">
      <div class="relative lg:col-span-7 min-h-[350px] lg:min-h-full overflow-hidden">
        <img
          src={image}
          alt={`${event.name} venue space at Park 101 Carlsbad`}
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div class="lg:col-span-5 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-20 bg-brand-dark">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            Private Events
          </span>
          <h1 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-4">
            {event.name}
          </h1>
          <p class="font-body font-light text-brand-cream/70 text-base sm:text-lg leading-relaxed mb-6">
            {event.headline}
          </p>
          <div class="inline-block px-4 py-2 border border-brand-orange/40 mb-8">
            <span class="font-display font-bold text-xs uppercase tracking-stat text-brand-orange">{event.capacity}</span>
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={`mailto:${siteProfile.contact.email}?subject=Private Event Inquiry - ${event.name}`}
              class="px-6 py-3.5 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-xs transition-colors duration-200 text-center"
            >
              Email Us
            </a>
            <a
              href={`tel:${siteProfile.contact.phoneDial}`}
              class="px-6 py-3.5 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200 text-center"
            >
              {siteProfile.contact.phone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── DESCRIPTION ──────────────────────────────────────── -->
  <section class="relative bg-brand-cream py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-brand-dark uppercase tracking-tight mb-6">
        {event.headline}
      </h2>
      <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed">
        {event.description} Located one block from the beach in Carlsbad Village, Park 101 gives your event the rooftop, the courtyard, or the whole place — your call.
      </p>
    </div>
  </section>

  <!-- ── WHAT'S INCLUDED ──────────────────────────────────── -->
  <section class="relative bg-brand-tan py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-dark/70 mb-3">
          What's Included
        </span>
        <h2 class="font-display font-bold text-3xl sm:text-4xl text-brand-dark uppercase tracking-tight">
          Everything Handled
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {event.features.map((feature) => (
          <div class="flex items-center gap-3 bg-brand-cream/60 px-5 py-4">
            <span class="w-1.5 h-1.5 bg-brand-orange flex-shrink-0"></span>
            <span class="font-display font-bold text-sm uppercase tracking-wide text-brand-dark">{feature}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── BACK + CROSS-LINK ────────────────────────────────── -->
  <section class="bg-brand-dark py-16 px-6 sm:px-8 lg:px-12 text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-brand-white uppercase leading-display tracking-tight mb-6">
        Ready to Book {event.name}?
      </h2>
      <p class="font-body font-light text-brand-cream/70 text-base leading-relaxed mb-8">
        Our events team responds within 24 hours with availability and a custom plan.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <a
          href={`mailto:${siteProfile.contact.email}?subject=Private Event Inquiry - ${event.name}`}
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
        >
          Email Us
        </a>
        <a
          href="/venue"
          class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
        >
          See the Venue
        </a>
      </div>
      <a href="/private-events" class="font-body text-sm text-brand-cream/60 hover:text-brand-orange transition-colors duration-150">
        ← All Event Types
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

</Layout>
