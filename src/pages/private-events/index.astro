---
import Layout from '../../layouts/Layout.astro';
import siteProfile from '../../data/site-profile.json';
import { privateEventsHubImage, privateEventImages } from '../../data/private-events-images';
import EventInquiryForm from '../../components/core/EventInquiryForm.astro';
import PrivateEventCard from '../../components/private-events/PrivateEventCard.astro';

const events = siteProfile.privateEvents;

const faqs = [
  {
    q: "What's the minimum guest count for a private event?",
    a: "Smaller semi-private setups work for intimate groups, and full buyouts scale up from there. Tell us your headcount and we'll find the right space.",
  },
  {
    q: 'Can I customize the food and drink menu?',
    a: 'Yes. Smokehouse platters, taco bars, and drink packages — we build the menu around your event and your crowd.',
  },
  {
    q: 'Can I book just the rooftop, or does it have to be the whole venue?',
    a: "Either works. Reserve a section, the rooftop, the courtyard, or buy out the entire place — it depends on your group size and what you're celebrating.",
  },
  {
    q: 'Do you have AV or sound for music and presentations?',
    a: 'Yes — the LED wall, sound system, and screens are available for game day watch parties, presentations, or your own playlist.',
  },
  {
    q: 'How far in advance should I book?',
    a: 'We recommend reaching out as early as possible, especially for weekend dates and game day buyouts — but we always do what we can to accommodate shorter timelines.',
  },
  {
    q: 'Is parking available nearby?',
    a: 'Park 101 is one block from the beach in Carlsbad Village. Street parking and public lots are available nearby.',
  },
];

const howItWorks = [
  { step: '01', title: 'Reach Out', body: "Tell us your date, headcount, and what you're celebrating. We respond within 24 hours." },
  { step: '02', title: 'Get a Custom Plan', body: 'Menu, space, drink packages, and pricing built around your event.' },
  { step: '03', title: 'Lock It In', body: 'Confirm the details and secure your date with a deposit.' },
  { step: '04', title: 'Show Up', body: 'We handle the rest. You and your crew just show up and enjoy it.' },
];

const pageTitle = 'Private Event Venue in Carlsbad Village | PRK 101';
const pageDescription =
  'Host your next birthday, corporate event, or full venue buyout at Park 101 in Carlsbad Village. Up to 300 guests, 5 event types, rooftop and courtyard spaces available.';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} ogImage={siteProfile.seo.ogImage} transparentNav={true}>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-[650px] bg-brand-dark flex flex-col overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={privateEventsHubImage}
        alt="Evening private event gathering on the rooftop at Park 101 Carlsbad"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-brand-dark/65"></div>
    </div>
    <div class="h-20 shrink-0"></div>
    <div class="relative z-10 flex-1 flex items-center justify-center px-6 sm:px-8 lg:px-12 pb-16">
    <div class="max-w-3xl mx-auto text-center">
      <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">
        Group Bookings
      </span>
      <h1 class="font-display font-bold text-section-xl text-brand-white uppercase leading-ultra tracking-tight mb-6">
        Private Events
      </h1>
      <p class="font-body font-light text-brand-cream/80 text-lg leading-relaxed mb-8 max-w-xl mx-auto">
        Birthdays, corporate buyouts, game day takeovers, and everything in between. Park 101's rooftop, courtyard, and indoor spaces are yours to fill.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#inquiry"
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
        >
          Request Availability
        </a>
        <a
          href={`tel:${siteProfile.contact.phoneDial}`}
          class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
        >
          Call Us
        </a>
      </div>
    </div>
    </div>
  </section>

  <!-- ── STAT BAR ─────────────────────────────────────────── -->
  <section class="bg-brand-dark/95 border-t border-brand-white/10 py-8 px-6 sm:px-8 lg:px-12">
    <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-y-6 gap-x-4 md:divide-x divide-brand-white/10 text-center">
      <div class="px-4">
        <span class="block font-display font-bold text-2xl text-brand-white uppercase tracking-wide">300</span>
        <span class="block font-body text-xs tracking-stat uppercase text-brand-orange mt-1">Max Guests</span>
      </div>
      <div class="px-4">
        <span class="block font-display font-bold text-2xl text-brand-white uppercase tracking-wide">5</span>
        <span class="block font-body text-xs tracking-stat uppercase text-brand-orange mt-1">Event Types</span>
      </div>
      <div class="px-4">
        <span class="block font-display font-bold text-2xl text-brand-white uppercase tracking-wide">2</span>
        <span class="block font-body text-xs tracking-stat uppercase text-brand-orange mt-1">Levels</span>
      </div>
      <div class="px-4">
        <span class="block font-display font-bold text-2xl text-brand-white uppercase tracking-wide">24-Hr</span>
        <span class="block font-body text-xs tracking-stat uppercase text-brand-orange mt-1">Response Time</span>
      </div>
    </div>
  </section>

  <!-- ── WHY PARK 101 ─────────────────────────────────────── -->
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="relative lg:col-span-6 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/venue/park-101-outdoor-fire-pit-patio-venue-carlsbad.jpg"
          alt="Full multi-level venue at Park 101 Carlsbad with courtyard, fire pit, and rooftop"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
      <div class="lg:col-span-6 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
            Why Park 101
          </span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">
            A Venue Worth Filling
          </h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8">
            Park 101 isn't a banquet room — it's the rooftop deck, the open-air courtyard with the LED wall, and the indoor bar, all under one roof in Carlsbad Village. Each space has its own character and can be configured for groups of any size.
          </p>
          <a
            href="/venue"
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            See the Full Venue
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── BROWSE BY EVENT TYPE ─────────────────────────────── -->
  <section class="relative bg-brand-dark py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-14">
        <span class="block font-body text-xs font-bold tracking-eyebrow-wide uppercase text-brand-orange mb-3">
          Browse by Event Type
        </span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight">
          Every Occasion, Handled
        </h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {events.map((event) => (
          <PrivateEventCard event={event} image={privateEventImages[event.slug]} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ──────────────────────────────────────── -->
  <section class="relative bg-brand-cream py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-5xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-14">
        <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
          How It Works
        </span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase tracking-tight">
          From First Inquiry to Your Event
        </h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {howItWorks.map((item) => (
          <div>
            <span class="block font-display font-bold text-3xl text-brand-orange mb-3">{item.step}</span>
            <h3 class="font-display font-bold text-lg uppercase tracking-tight text-brand-dark mb-2">{item.title}</h3>
            <p class="font-body font-light text-brand-dark/70 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── INQUIRY FORM ─────────────────────────────────────── -->
  <EventInquiryForm />

  <!-- ── FAQ ───────────────────────────────────────────────── -->
  <section id="faq" class="relative bg-brand-steel py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-14">
        <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
          Common Questions
        </span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight">
          Private Events FAQ
        </h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="space-y-6">
        {faqs.map((item) => (
          <div class="border-b border-brand-white/15 pb-6">
            <h3 class="font-display font-bold text-base uppercase tracking-tight text-brand-white mb-2">{item.q}</h3>
            <p class="font-body font-light text-brand-cream/70 text-sm leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────────── -->
  <section class="relative bg-brand-dark py-20 px-6 sm:px-8 lg:px-12 text-center">
    <div class="max-w-2xl mx-auto">
      <span class="block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">
        Let's Make It Happen
      </span>
      <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6">
        Ready to Start Planning?
      </h2>
      <p class="font-body font-light text-brand-cream/80 text-base sm:text-lg leading-relaxed mb-8">
        Our events team responds within 24 hours with availability and a custom plan.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#inquiry"
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
        >
          Request Availability
        </a>
        <a
          href={`tel:${siteProfile.contact.phoneDial}`}
          class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
        >
          {siteProfile.contact.phone}
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

</Layout>
