---
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
import EventInquiryForm from '../../components/core/EventInquiryForm.astro';
import StatBar from '../../components/core/StatBar.astro';
import PrivateEventCard from '../../components/private-events/PrivateEventCard.astro';

const siteProfile = (await getEntry('siteSettings', 'site-settings'))!.data;
const page = (await getCollection('privateEventsIndex'))[0].data;
const eventOrder = ['birthday-parties', 'corporate-events', 'venue-buyout', 'game-day-parties', 'rehearsal-dinners'];
const events = (await getCollection('privateEvents'))
  .map(({ data }) => data)
  .sort((a, b) => eventOrder.indexOf(a.slug) - eventOrder.indexOf(b.slug));
const faqs = page.faqs!;
const howItWorks = page.howItWorks!;
const privateEventsHubImage = page.seo.ogImage;

const pageTitle = page.seo.title;
const pageDescription = page.seo.description;
const blockText = (value: string) => `\n${value}\n`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout title={pageTitle} description={pageDescription} ogImage={privateEventsHubImage} transparentNav={true}>

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <section class="relative min-h-[650px] bg-brand-dark flex flex-col overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={privateEventsHubImage}
        alt="Evening private event gathering on the rooftop at Park 101 Carlsbad"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-brand-dark/65"></div>
    </div>
    <div class="h-20 shrink-0"></div>
    <div class="relative z-10 flex-1 flex items-center justify-center px-6 sm:px-8 lg:px-12 pb-16">
    <div class="max-w-3xl mx-auto text-center">
      <span class="inline-block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4">{blockText(page.hero.eyebrow)}</span>
      <h1 class="font-display font-bold text-section-xl text-brand-white uppercase leading-ultra tracking-tight mb-6">{blockText(page.hero.heading)}</h1>
      <p class="font-body font-light text-brand-cream/80 text-lg leading-relaxed mb-8 max-w-xl mx-auto"><Fragment set:html={blockText(page.hero.body!)} /></p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#inquiry"
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
        >
          Request Availability
        </a>
        <a
          href={`tel:${siteProfile.contact.phoneDial}`}
          class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
        >
          Call Us
        </a>
      </div>
    </div>
    </div>
  </section>

  <!-- ── STAT BAR ─────────────────────────────────────────── -->
  <StatBar stats={[
    { value: '300', label: 'Max Guests' },
    { value: '5', label: 'Event Types' },
    { value: '2', label: 'Levels' },
    { value: '24-Hr', label: 'Response Time' },
  ]} />

  <!-- ── WHY PARK 101 ─────────────────────────────────────── -->
  <section class="relative bg-brand-cream">
    <div class="grid grid-cols-1 lg:grid-cols-12 items-stretch min-h-[600px]">
      <div class="relative lg:col-span-6 min-h-[400px] lg:min-h-full overflow-hidden">
        <img
          src="/images/venue/park-101-outdoor-fire-pit-patio-venue-carlsbad.jpg"
          alt="Full multi-level venue at Park 101 Carlsbad with courtyard, fire pit, and rooftop"
          class="absolute inset-0 w-full h-full object-cover object-center"
          loading="lazy"
        />
      </div>
      <div class="lg:col-span-6 flex flex-col justify-center px-6 sm:px-12 lg:px-16 py-16 lg:py-24 bg-brand-cream">
        <div class="max-w-md mx-auto lg:mx-0">
          <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(page.intro!.eyebrow)}</span>
          <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-6">{blockText(page.intro!.heading)}</h2>
          <div class="w-12 h-[2px] bg-brand-orange mb-6"></div>
          <p class="font-body font-light text-brand-dark/75 text-base sm:text-lg leading-relaxed mb-8"><Fragment set:html={blockText(page.intro!.body!)} /></p>
          <a
            href="/venue"
            class="inline-block px-6 py-3.5 border border-brand-dark hover:bg-brand-dark hover:text-brand-white text-brand-dark font-display font-bold uppercase tracking-button-outline text-xs transition-all duration-200"
          >
            See the Full Venue
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── BROWSE BY EVENT TYPE ─────────────────────────────── -->
  <section class="relative bg-brand-dark py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-14">
        <span class="block font-body text-xs font-bold tracking-eyebrow-wide uppercase text-brand-orange mb-3">{blockText(page.sections.types.eyebrow)}</span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight">{blockText(page.sections.types.heading)}</h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {events.map((event) => (
          <PrivateEventCard event={event} image={event.image} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ──────────────────────────────────────── -->
  <section class="relative bg-brand-cream py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-5xl mx-auto">
      <div class="text-center max-w-xl mx-auto mb-14">
        <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(page.sections.process.eyebrow)}</span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase tracking-tight">{blockText(page.sections.process.heading)}</h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {howItWorks.map((item) => (
          <div>
            <span class="block font-display font-bold text-3xl text-brand-orange mb-3">{item.step}</span>
            <h3 class="font-display font-bold text-lg uppercase tracking-tight text-brand-dark mb-2">{item.title}</h3>
            <p class="font-body font-light text-brand-dark/70 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── INQUIRY FORM ─────────────────────────────────────── -->
  <EventInquiryForm />

  <!-- ── FAQ ───────────────────────────────────────────────── -->
  <section id="faq" class="relative bg-brand-steel py-20 px-6 sm:px-8 lg:px-12">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-14">
        <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">{blockText(page.sections.faq.eyebrow)}</span>
        <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase tracking-tight">{blockText(page.sections.faq.heading)}</h2>
        <div class="w-12 h-[2px] bg-brand-orange mx-auto mt-5"></div>
      </div>

      <div class="space-y-6">
        {faqs.map((item) => (
          <div class="border-b border-brand-white/15 pb-6">
            <h3 class="font-display font-bold text-base uppercase tracking-tight text-brand-white mb-2">{item.q}</h3>
            <p class="font-body font-light text-brand-cream/70 text-sm leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FINAL CTA ─────────────────────────────────────────── -->
  <section class="relative bg-brand-dark py-20 px-6 sm:px-8 lg:px-12 text-center">
    <div class="max-w-2xl mx-auto">
      <span class="block font-body text-xs font-bold tracking-eyebrow-lg uppercase text-brand-orange mb-4"><Fragment set:html={blockText(page.sections.final.eyebrow)} /></span>
      <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-white uppercase leading-display tracking-tight mb-6">{blockText(page.sections.final.heading)}</h2>
      <p class="font-body font-light text-brand-cream/80 text-base sm:text-lg leading-relaxed mb-8">{blockText(page.sections.final.body!)}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="#inquiry"
          class="px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200 text-center"
        >
          Request Availability
        </a>
        <a
          href={`tel:${siteProfile.contact.phoneDial}`}
          class="px-8 py-4 border border-brand-white/60 hover:border-brand-white hover:bg-brand-white/10 text-brand-white font-display font-bold uppercase tracking-button-outline text-sm transition-all duration-200 text-center"
        >
          {siteProfile.contact.phone}
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

</Layout>
