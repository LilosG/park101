---
interface Props {
  event: {
    slug: string;
    name: string;
    description: string;
  };
  image: string;
}

const { event, image } = Astro.props;
---

<a
  href={`/private-events/${event.slug}`}
  class="group block bg-brand-dark-light overflow-hidden"
>
  <div class="relative aspect-[4/3] overflow-hidden">
    <img
      src={image}
      alt={`${event.name} at Park 101 Carlsbad`}
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="p-6">
    <h3 class="font-display font-bold text-xl uppercase tracking-tight text-brand-white mb-2">
      {event.name}
    </h3>
    <p class="font-body font-light text-brand-cream/70 text-sm leading-relaxed mb-3">
      {event.description}
    </p>
    <span class="font-display font-bold text-xs uppercase tracking-button text-brand-orange">
      Learn More →
    </span>
  </div>
</a>
