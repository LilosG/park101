---
import siteProfile from '../../data/site-profile.json';

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Menu',                href: '/menu' },
  { label: 'Brunch',              href: '/brunch' },
  { label: 'North County Lineup', href: '/north-county-lineup' },
  { label: 'The Venue',           href: '/venue' },
  { label: 'Private Events',      href: '/private-events' },
  { label: 'Blog',                href: '/blog' },
  { label: 'Contact',             href: '/contact' },
];
---

<header
  id="site-nav"
  class={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${transparent ? 'nav-transparent' : 'nav-solid'}`}
  data-transparent={transparent ? 'true' : 'false'}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0" aria-label="Park 101 Home">
        <span class="font-display font-black text-3xl tracking-widest uppercase nav-logo-text transition-colors duration-300">
          PRK 101
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-0.5" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`nav-link px-2.5 py-2 text-xs font-display font-bold uppercase tracking-wider transition-colors duration-200 whitespace-nowrap ${
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href + '/'))
                ? 'nav-link-active'
                : ''
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTAs -->
      <div class="hidden lg:flex items-center gap-3 flex-shrink-0">
        <a
          href={siteProfile.ordering.toastUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 text-xs font-display font-bold uppercase tracking-wider border border-current nav-cta-outline transition-all duration-200 hover:bg-brand-orange hover:border-brand-orange hover:text-brand-white rounded-sm whitespace-nowrap"
        >
          Order Takeout
        </a>
        <a
          href={siteProfile.ordering.reservationsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 text-xs font-display font-bold uppercase tracking-wider bg-brand-orange text-brand-white hover:bg-brand-orange-dark transition-colors duration-200 rounded-sm whitespace-nowrap"
        >
          Reserve
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-bar block w-6 h-0.5 bg-current transition-all duration-300"></span>
        <span class="hamburger-bar block w-6 h-0.5 bg-current transition-all duration-300"></span>
        <span class="hamburger-bar block w-6 h-0.5 bg-current transition-all duration-300"></span>
      </button>

    </div>
  </div>
</header>

<!-- Mobile Full-Screen Drawer -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-brand-dark flex flex-col justify-center px-8 opacity-0 invisible transition-all duration-300"
  aria-hidden="true"
>
  <!-- Close button -->
  <button
    id="mobile-close-btn"
    class="absolute top-6 right-6 text-brand-white p-2"
    aria-label="Close menu"
  >
    <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Mobile Logo -->
  <div class="mb-10">
    <span class="font-display font-black text-4xl tracking-widest uppercase text-brand-white">PRK 101</span>
  </div>

  <!-- Mobile Links -->
  <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="py-3 text-2xl font-display font-bold uppercase tracking-wider text-brand-white hover:text-brand-orange transition-colors duration-150 border-b border-brand-dark-light"
      >
        {link.label}
      </a>
    ))}
  </nav>

  <!-- Mobile CTAs -->
  <div class="flex flex-col gap-3 mt-10">
    <a
      href={siteProfile.ordering.toastUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="w-full py-4 text-center text-lg font-display font-bold uppercase tracking-wider border border-brand-white text-brand-white hover:bg-brand-orange hover:border-brand-orange transition-all duration-200 rounded-sm"
    >
      Order Takeout
    </a>
    <a
      href={siteProfile.ordering.reservationsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="w-full py-4 text-center text-lg font-display font-bold uppercase tracking-wider bg-brand-orange text-brand-white hover:bg-brand-orange-dark transition-colors duration-200 rounded-sm"
    >
      Reserve a Table
    </a>
  </div>
</div>

<style>
  /* Transparent state — over hero images */
  .nav-transparent {
    background: transparent;
  }
  .nav-transparent .nav-link,
  .nav-transparent .nav-logo-text,
  .nav-transparent #mobile-menu-btn {
    color: var(--color-brand-white);
  }
  .nav-transparent .nav-cta-outline {
    color: var(--color-brand-white);
    border-color: rgba(253, 250, 247, 0.6);
  }

  /* Solid state */
  .nav-solid {
    background: var(--color-brand-dark);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .nav-solid .nav-link,
  .nav-solid .nav-logo-text,
  .nav-solid #mobile-menu-btn {
    color: var(--color-brand-white);
  }
  .nav-solid .nav-cta-outline {
    color: var(--color-brand-white);
    border-color: rgba(253, 250, 247, 0.4);
  }

  /* Active link */
  .nav-link-active {
    color: var(--color-brand-orange) !important;
  }

  /* Scrolled state — applied by JS */
  .nav-scrolled {
    background: var(--color-brand-dark) !important;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .nav-scrolled .nav-link,
  .nav-scrolled .nav-logo-text,
  .nav-scrolled #mobile-menu-btn {
    color: var(--color-brand-white) !important;
  }

  /* Mobile drawer open state */
  #mobile-menu.menu-open {
    opacity: 1;
    visibility: visible;
  }

  /* Hamburger → X animation */
  .menu-open-bars .hamburger-bar:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .menu-open-bars .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-open-bars .hamburger-bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  const header = document.getElementById('site-nav');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileCloseBtn = document.getElementById('mobile-close-btn');
  const isTransparent = header?.dataset.transparent === 'true';

  // Transparent nav solidifies on scroll
  if (isTransparent && header) {
    const onScroll = () => {
      if (window.scrollY > 50) {
        header.classList.add('nav-scrolled');
        header.classList.remove('nav-transparent');
      } else {
        header.classList.remove('nav-scrolled');
        header.classList.add('nav-transparent');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Open mobile drawer
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.add('menu-open');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    mobileMenuBtn.setAttribute('aria-expanded', 'true');
    mobileMenuBtn.classList.add('menu-open-bars');
    document.body.style.overflow = 'hidden';
  });

  // Close mobile drawer
  const closeMenu = () => {
    mobileMenu?.classList.remove('menu-open');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    mobileMenuBtn?.classList.remove('menu-open-bars');
    document.body.style.overflow = '';
  };

  mobileCloseBtn?.addEventListener('click', closeMenu);
  mobileMenu?.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMenu));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
</script>
