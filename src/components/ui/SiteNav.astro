---
import siteProfile from '../../data/site-profile.json';

interface Props {
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Menu', href: '/menu' },
  { label: 'Weekly Specials', href: '/weekly-specials' },
  {
    label: 'Venue',
    href: '#',
    dropdown: [
      { label: 'Rooftop', href: '/venue/rooftop' },
      { label: 'Sports & Game Day', href: '/venue/sports' },
      { label: 'Families & Pets', href: '/venue/families-pets' },
      { label: 'Live Events', href: '/venue/live-events' },
    ],
  },
  { label: 'Private Events', href: '/private-events' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];
---

<header
  id="site-nav"
  class={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${transparent ? 'nav-transparent' : 'nav-solid'}`}
  data-transparent={transparent ? 'true' : 'false'}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center flex-shrink-0 group" aria-label="Park 101 Home">
        <span class="font-display font-900 text-3xl tracking-widest uppercase nav-logo-text transition-colors duration-300">
          PRK 101
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map((link) => (
          link.dropdown ? (
            <div class="relative group/dropdown">
              <button
                class={`nav-link flex items-center gap-1 px-3 py-2 text-sm font-display font-700 uppercase tracking-wider transition-colors duration-200 ${currentPath.startsWith('/venue') ? 'nav-link-active' : ''}`}
                aria-haspopup="true"
                aria-expanded="false"
              >
                {link.label}
                <svg class="w-3 h-3 transition-transform duration-200 group-hover/dropdown:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <!-- Dropdown -->
              <div class="absolute top-full left-0 mt-1 w-52 opacity-0 invisible group-hover/dropdown:opacity-100 group-hover/dropdown:visible transition-all duration-200 translate-y-1 group-hover/dropdown:translate-y-0">
                <div class="bg-brand-dark border border-brand-dark-light rounded-md overflow-hidden shadow-2xl">
                  {link.dropdown.map((item) => (
                    <a
                      href={item.href}
                      class={`block px-4 py-3 text-sm font-display font-600 uppercase tracking-wider text-brand-white hover:bg-brand-orange hover:text-brand-white transition-colors duration-150 ${currentPath === item.href ? 'bg-brand-orange text-brand-white' : ''}`}
                    >
                      {item.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class={`nav-link px-3 py-2 text-sm font-display font-700 uppercase tracking-wider transition-colors duration-200 ${currentPath === link.href ? 'nav-link-active' : ''}`}
            >
              {link.label}
            </a>
          )
        ))}
      </nav>

      <!-- Desktop CTAs -->
      <div class="hidden lg:flex items-center gap-3">
        <a
          href={siteProfile.ordering.toastUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 text-sm font-display font-700 uppercase tracking-wider border border-current nav-cta-outline transition-all duration-200 hover:bg-brand-orange hover:border-brand-orange hover:text-brand-white rounded-sm"
        >
          Order Takeout
        </a>
        <a
          href={siteProfile.ordering.reservationsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="px-4 py-2 text-sm font-display font-700 uppercase tracking-wider bg-brand-orange text-brand-white hover:bg-brand-orange-dark transition-colors duration-200 rounded-sm"
        >
          Reserve
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-bar block w-6 h-0.5 bg-current transition-all duration-300"></span>
        <span class="hamburger-bar block w-6 h-0.5 bg-current transition-all duration-300"></span>
        <span class="hamburger-bar block w-6 h-0.5 bg-current transition-all duration-300"></span>
      </button>

    </div>
  </div>
</header>

<!-- Mobile Full-Screen Drawer -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-brand-dark flex flex-col justify-center px-8 opacity-0 invisible transition-all duration-300"
  aria-hidden="true"
>
  <!-- Close button -->
  <button
    id="mobile-close-btn"
    class="absolute top-6 right-6 text-brand-white p-2"
    aria-label="Close menu"
  >
    <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Mobile Logo -->
  <div class="mb-10">
    <span class="font-display font-900 text-4xl tracking-widest uppercase text-brand-white">PRK 101</span>
  </div>

  <!-- Mobile Links -->
  <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
    {navLinks.map((link) => (
      link.dropdown ? (
        <div>
          <span class="block px-0 py-3 text-2xl font-display font-700 uppercase tracking-wider text-brand-tan border-b border-brand-dark-light">
            {link.label}
          </span>
          <div class="pl-4 mt-1 mb-2 flex flex-col gap-1">
            {link.dropdown.map((item) => (
              <a
                href={item.href}
                class="py-2 text-xl font-display font-600 uppercase tracking-wider text-brand-white hover:text-brand-orange transition-colors duration-150"
              >
                {item.label}
              </a>
            ))}
          </div>
        </div>
      ) : (
        <a
          href={link.href}
          class="py-3 text-2xl font-display font-700 uppercase tracking-wider text-brand-white hover:text-brand-orange transition-colors duration-150 border-b border-brand-dark-light"
        >
          {link.label}
        </a>
      )
    ))}
  </nav>

  <!-- Mobile CTAs -->
  <div class="flex flex-col gap-3 mt-10">
    <a
      href={siteProfile.ordering.toastUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="w-full py-4 text-center text-lg font-display font-700 uppercase tracking-wider border border-brand-white text-brand-white hover:bg-brand-orange hover:border-brand-orange transition-all duration-200 rounded-sm"
    >
      Order Takeout
    </a>
    <a
      href={siteProfile.ordering.reservationsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="w-full py-4 text-center text-lg font-display font-700 uppercase tracking-wider bg-brand-orange text-brand-white hover:bg-brand-orange-dark transition-colors duration-200 rounded-sm"
    >
      Reserve a Table
    </a>
  </div>
</div>

<style>
  /* Transparent state — used over hero */
  .nav-transparent {
    background: transparent;
  }
  .nav-transparent .nav-link,
  .nav-transparent .nav-logo-text,
  .nav-transparent button:not(#mobile-menu-btn ~ *) {
    color: #FDFAF7;
  }
  .nav-transparent #mobile-menu-btn {
    color: #FDFAF7;
  }
  .nav-transparent .nav-cta-outline {
    color: #FDFAF7;
    border-color: rgba(253, 250, 247, 0.6);
  }

  /* Solid state — after scroll */
  .nav-solid {
    background: #1B140F;
    box-shadow: 0 1px 0 rgba(255,255,255,0.06);
  }
  .nav-solid .nav-link,
  .nav-solid .nav-logo-text {
    color: #FDFAF7;
  }
  .nav-solid #mobile-menu-btn {
    color: #FDFAF7;
  }
  .nav-solid .nav-cta-outline {
    color: #FDFAF7;
    border-color: rgba(253, 250, 247, 0.4);
  }

  /* Active link */
  .nav-link-active {
    color: #C4622D !important;
  }

  /* Scrolled solid state applied via JS */
  .nav-scrolled {
    background: #1B140F !important;
    box-shadow: 0 1px 0 rgba(255,255,255,0.06);
  }
  .nav-scrolled .nav-link,
  .nav-scrolled .nav-logo-text,
  .nav-scrolled #mobile-menu-btn {
    color: #FDFAF7 !important;
  }

  /* Mobile drawer open state */
  #mobile-menu.menu-open {
    opacity: 1;
    visibility: visible;
  }

  /* Hamburger → X animation */
  .menu-open-bars .hamburger-bar:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }
  .menu-open-bars .hamburger-bar:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-open-bars .hamburger-bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }
</style>

<script>
  const header = document.getElementById('site-nav');
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileCloseBtn = document.getElementById('mobile-close-btn');
  const isTransparent = header?.dataset.transparent === 'true';

  // Scroll handler — transparent nav solidifies on scroll
  if (isTransparent && header) {
    const onScroll = () => {
      if (window.scrollY > 50) {
        header.classList.add('nav-scrolled');
        header.classList.remove('nav-transparent');
      } else {
        header.classList.remove('nav-scrolled');
        header.classList.add('nav-transparent');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Mobile drawer open
  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.add('menu-open');
    mobileMenu?.setAttribute('aria-hidden', 'false');
    mobileMenuBtn.setAttribute('aria-expanded', 'true');
    mobileMenuBtn.classList.add('menu-open-bars');
    document.body.style.overflow = 'hidden';
  });

  // Mobile drawer close
  const closeMenu = () => {
    mobileMenu?.classList.remove('menu-open');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    mobileMenuBtn?.setAttribute('aria-expanded', 'false');
    mobileMenuBtn?.classList.remove('menu-open-bars');
    document.body.style.overflow = '';
  };

  mobileCloseBtn?.addEventListener('click', closeMenu);

  // Close on nav link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>
