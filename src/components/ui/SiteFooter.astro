---
import siteProfile from '../../data/site-profile.json';
import { GPH_NETWORK, GRIND_AND_PROSPER_URL } from '../../data/gphNetwork';

const portfolio = GPH_NETWORK.filter((v) => v.url !== siteProfile.url);
---

<footer class="bg-brand-dark text-brand-white">

  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">

      <!-- Col 1: Brand -->
      <div>
        <a href="/" aria-label="Park 101 Home">
          <span class="font-display font-black text-4xl tracking-widest uppercase text-brand-white">
            PRK 101
          </span>
        </a>
        <p class="mt-4 text-sm text-brand-white/60 leading-relaxed max-w-xs">
          {siteProfile.shortDescription}
        </p>
        <p class="mt-4 text-xs font-display font-bold uppercase tracking-widest text-brand-orange">
          {siteProfile.tagline}
        </p>
        <!-- Social -->
        <div class="flex gap-4 mt-6">
          {siteProfile.social.instagram && (
            <a
              href={siteProfile.social.instagram}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Park 101 on Instagram"
              class="text-brand-white/50 hover:text-brand-orange transition-colors duration-200"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          )}
          {siteProfile.social.facebook && (
            <a
              href={siteProfile.social.facebook}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Park 101 on Facebook"
              class="text-brand-white/50 hover:text-brand-orange transition-colors duration-200"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          )}
        </div>
      </div>

      <!-- Col 2: Nav Links -->
      <div>
        <h3 class="font-display font-bold text-xs uppercase tracking-widest text-brand-orange mb-6">
          Explore
        </h3>
        <nav aria-label="Footer navigation">
          <ul class="flex flex-col gap-3">
            <li><a href="/menu" class="text-sm text-brand-white/70 hover:text-brand-orange transition-colors duration-150 font-display font-semibold uppercase tracking-wide">Menu</a></li>
            <li><a href="/brunch" class="text-sm text-brand-white/70 hover:text-brand-orange transition-colors duration-150 font-display font-semibold uppercase tracking-wide">Brunch</a></li>
            <li><a href="/north-county-lineup" class="text-sm text-brand-white/70 hover:text-brand-orange transition-colors duration-150 font-display font-semibold uppercase tracking-wide">North County Lineup</a></li>
            <li><a href="/venue" class="text-sm text-brand-white/70 hover:text-brand-orange transition-colors duration-150 font-display font-semibold uppercase tracking-wide">The Venue</a></li>
            <li><a href="/private-events" class="text-sm text-brand-white/70 hover:text-brand-orange transition-colors duration-150 font-display font-semibold uppercase tracking-wide">Private Events</a></li>
            <li><a href="/blog" class="text-sm text-brand-white/70 hover:text-brand-orange transition-colors duration-150 font-display font-semibold uppercase tracking-wide">Blog</a></li>
            <li><a href="/contact" class="text-sm text-brand-white/70 hover:text-brand-orange transition-colors duration-150 font-display font-semibold uppercase tracking-wide">Contact</a></li>
          </ul>
        </nav>
      </div>

      <!-- Col 3: Hours + Address -->
      <div>
        <h3 class="font-display font-bold text-xs uppercase tracking-widest text-brand-orange mb-6">
          Visit Us
        </h3>

        <!-- Address -->
        <a
          href={siteProfile.contact.googleMapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group block mb-6"
        >
          <address class="not-italic text-sm text-brand-white/70 leading-relaxed group-hover:text-brand-orange transition-colors duration-150">
            {siteProfile.contact.address.street}<br />
            {siteProfile.contact.address.city}, {siteProfile.contact.address.state} {siteProfile.contact.address.zip}
          </address>
        </a>

        <!-- Phone -->
        <a
          href={`tel:${siteProfile.contact.phoneDial}`}
          class="block text-sm text-brand-white/70 hover:text-brand-orange transition-colors duration-150 mb-6 font-display font-semibold tracking-wide"
        >
          {siteProfile.contact.phone}
        </a>

        <!-- Hours -->
        <div>
          <p class="font-display font-bold text-xs uppercase tracking-widest text-brand-white/40 mb-3">Hours</p>
          <ul class="flex flex-col gap-1.5">
            {siteProfile.hoursDisplay.map((row) => (
              <li class="flex justify-between gap-4 text-xs text-brand-white/60">
                <span class="font-display font-semibold uppercase tracking-wide">{row.days}</span>
                <span class="text-brand-white/80 whitespace-nowrap">{row.hours}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTAs -->
        <div class="flex gap-3 mt-8">
          <a
            href={siteProfile.ordering.toastUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 py-2.5 text-center text-xs font-display font-bold uppercase tracking-wider border border-brand-white/30 text-brand-white/70 hover:border-brand-orange hover:text-brand-orange transition-all duration-200 rounded-sm"
          >
            Order
          </a>
          <a
            href={siteProfile.ordering.reservationsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 py-2.5 text-center text-xs font-display font-bold uppercase tracking-wider bg-brand-orange text-brand-white hover:bg-brand-orange-dark transition-colors duration-200 rounded-sm"
          >
            Reserve
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- GPH Network -->
  <div class="border-t border-brand-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8">
        <a href={GRIND_AND_PROSPER_URL} target="_blank" rel="noopener noreferrer"
          class="text-[10px] font-display font-bold uppercase tracking-widest text-brand-white/30 hover:text-brand-orange transition-colors whitespace-nowrap">
          Grind &amp; Prosper Hospitality
        </a>
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          {portfolio.map((v) => (
            <a href={v.url} target="_blank" rel="noopener noreferrer"
              class="text-xs text-brand-white/25 hover:text-brand-white/60 transition-colors">
              {v.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-brand-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-brand-white/30">
        &copy; {new Date().getFullYear()} {siteProfile.name}. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <p class="text-xs text-brand-white/20">
          {siteProfile.contact.neighborhood}, {siteProfile.contact.address.state} &mdash; {siteProfile.tagline}
        </p>
        <a href="https://lilosgrowth.com" target="_blank" rel="noopener noreferrer"
          class="text-brand-white/50 hover:text-brand-orange text-[13px] transition-colors">
          Website by Lilos Growth
        </a>
      </div>
    </div>
  </div>

</footer>
