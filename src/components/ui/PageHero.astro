---
interface Props {
  image: string;
  imageAlt: string;
  eyebrow?: string;
  heading: string;
  subheading?: string;
  ctaLabel?: string;
  ctaHref?: string;
  ctaSecondaryLabel?: string;
  ctaSecondaryHref?: string;
  size?: 'full' | 'large' | 'medium';
}

const {
  image,
  imageAlt,
  eyebrow,
  heading,
  subheading,
  ctaLabel,
  ctaHref,
  ctaSecondaryLabel,
  ctaSecondaryHref,
  size = 'large',
} = Astro.props;

const sizeClass = {
  full:   'min-h-screen',
  large:  'min-h-[80vh]',
  medium: 'min-h-[60vh]',
};
---

<section class={`relative overflow-hidden flex flex-col justify-end ${sizeClass[size]}`}>

  <!-- Background Image -->
  <img
    src={image}
    alt={imageAlt}
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />

  <!-- Gradient Overlay — bottom-heavy for legibility -->
  <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/40 to-transparent"></div>

  <!-- Hero Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-32 w-full">
    {eyebrow && (
      <p class="font-display font-700 text-xs uppercase tracking-widest text-brand-orange mb-4">
        {eyebrow}
      </p>
    )}
    <h1 class="font-display font-900 text-5xl sm:text-6xl lg:text-7xl uppercase leading-none text-brand-white mb-4 max-w-4xl">
      {heading}
    </h1>
    {subheading && (
      <p class="text-base lg:text-lg text-brand-white/80 leading-relaxed mb-8 max-w-2xl">
        {subheading}
      </p>
    )}
    {(ctaLabel || ctaSecondaryLabel) && (
      <div class="flex flex-wrap gap-4">
        {ctaLabel && ctaHref && (
          <a
            href={ctaHref}
            class="inline-block px-7 py-3.5 font-display font-700 text-sm uppercase tracking-wider bg-brand-orange text-brand-white hover:bg-brand-orange-dark transition-colors duration-200 rounded-sm"
          >
            {ctaLabel}
          </a>
        )}
        {ctaSecondaryLabel && ctaSecondaryHref && (
          <a
            href={ctaSecondaryHref}
            class="inline-block px-7 py-3.5 font-display font-700 text-sm uppercase tracking-wider border border-brand-white/50 text-brand-white hover:border-brand-white hover:bg-brand-white/10 transition-all duration-200 rounded-sm"
          >
            {ctaSecondaryLabel}
          </a>
        )}
      </div>
    )}
    <slot />
  </div>

</section>
