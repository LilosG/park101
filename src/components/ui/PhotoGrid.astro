---
interface GridImage {
  src: string;
  alt: string;
  label?: string;
  href?: string;
  span?: 'normal' | 'wide' | 'tall';
}

interface Props {
  images: GridImage[];
  columns?: 2 | 3 | 4;
}

const { images, columns = 3 } = Astro.props;

const colClass = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-2 lg:grid-cols-4',
};
---

<div class={`grid ${colClass[columns]}`}>
  {images.map((img) => {
    const spanClass = img.span === 'wide' ? 'col-span-2' : img.span === 'tall' ? 'row-span-2' : '';
    const Tag = img.href ? 'a' : 'div';
    const tagProps = img.href ? { href: img.href } : {};

    return (
      <Tag
        {...tagProps}
        class={`group relative overflow-hidden aspect-square ${spanClass}`}
      >
        <img
          src={img.src}
          alt={img.alt}
          class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
        {img.label && (
          <div class="absolute inset-0 bg-brand-dark/0 group-hover:bg-brand-dark/50 transition-all duration-300 flex items-end">
            <span class="w-full px-4 py-3 font-display font-700 text-sm uppercase tracking-wider text-brand-white translate-y-full group-hover:translate-y-0 transition-transform duration-300">
              {img.label}
            </span>
          </div>
        )}
      </Tag>
    );
  })}
</div>
