---
import siteProfile from '../../data/site-profile.json';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schemaType?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = siteProfile.seo.ogImage,
  schemaType,
  noindex = false,
} = Astro.props;

const siteUrl = siteProfile.url;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const fullTitle = title.includes('Park 101')
  ? title
  : `${title} | Park 101 Carlsbad`;

// Base Organization/Restaurant schema
const baseSchema = {
  "@context": "https://schema.org",
  "@type": ["BarOrPub", "Restaurant"],
  "name": siteProfile.name,
  "alternateName": siteProfile.brandName,
  "description": siteProfile.description,
  "url": siteUrl,
  "telephone": siteProfile.contact.phoneDial,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": siteProfile.contact.address.street,
    "addressLocality": siteProfile.contact.address.city,
    "addressRegion": siteProfile.contact.address.state,
    "postalCode": siteProfile.contact.address.zip,
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": siteProfile.contact.coordinates.lat,
    "longitude": siteProfile.contact.coordinates.lng
  },
  "servesCuisine": siteProfile.schema.servesCuisine,
  "priceRange": siteProfile.schema.priceRange,
  "hasMap": siteProfile.contact.googleMapsUrl,
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday"], "opens": "16:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Thursday"], "opens": "16:00", "closes": "22:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Friday"], "opens": "11:00", "closes": "23:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "10:00", "closes": "23:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "10:00", "closes": "21:00" }
  ],
  "sameAs": [
    siteProfile.social.instagram,
    siteProfile.social.facebook
  ].filter(Boolean)
};
---

<!-- Primary Meta -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:site_name" content={siteProfile.name} />
<meta property="og:locale" content="en_US" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Local Business Schema -->
<script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />
