---
import { getEntry } from 'astro:content';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schemaType?: string;
  noindex?: boolean;
}

const siteProfile = (await getEntry('siteSettings', 'site-settings'))!.data;

const {
  title,
  description,
  canonical,
  ogImage = siteProfile.seo.ogImage,
  schemaType,
  noindex = false,
} = Astro.props;

const siteUrl = siteProfile.url;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const fullTitle = (title.includes('Park 101') || title.includes('PRK 101'))
  ? title
  : `${title} | Park 101 Carlsbad`;

// Convert "11:00 AM" / "9:00 PM" / "12:00 AM" (midnight) into schema.org's
// 24-hour HH:MM format. Midnight-as-closing-time is represented as "24:00"
// per schema.org convention for OpeningHoursSpecification.
function to24Hour(time: string, isClose = false): string {
  const match = time.trim().match(/^(\d{1,2}):(\d{2})\s*(AM|PM)$/i);
  if (!match) return time;
  let [, hourStr, minute, meridiem] = match;
  let hour = parseInt(hourStr, 10);
  if (meridiem.toUpperCase() === 'AM' && hour === 12) hour = 0;
  if (meridiem.toUpperCase() === 'PM' && hour !== 12) hour += 12;
  if (isClose && hour === 0 && minute === '00') return '24:00';
  return `${String(hour).padStart(2, '0')}:${minute}`;
}

const dayOrder = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'] as const;
const dayLabel: Record<(typeof dayOrder)[number], string> = {
  monday: 'Monday', tuesday: 'Tuesday', wednesday: 'Wednesday', thursday: 'Thursday',
  friday: 'Friday', saturday: 'Saturday', sunday: 'Sunday',
};

// Group consecutive days that share identical hours into a single spec,
// same as GBP does, so the schema stays compact and easy to eyeball against
// the GBP listing during future audits.
const openingHoursSpecification: Array<{
  '@type': string;
  dayOfWeek: string[];
  opens: string;
  closes: string;
}> = [];

for (const day of dayOrder) {
  const dayHours = siteProfile.hours[day];
  const opens = to24Hour(dayHours.open);
  const closes = to24Hour(dayHours.close, true);
  const last = openingHoursSpecification[openingHoursSpecification.length - 1];
  if (last && last.opens === opens && last.closes === closes) {
    last.dayOfWeek.push(dayLabel[day]);
  } else {
    openingHoursSpecification.push({
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: [dayLabel[day]],
      opens,
      closes,
    });
  }
}

// Base Organization/Restaurant schema
const baseSchema = {
  "@context": "https://schema.org",
  "@type": ["BarOrPub", "Restaurant"],
  "name": siteProfile.name,
  "alternateName": siteProfile.brandName,
  "description": siteProfile.description,
  "url": siteUrl,
  "telephone": siteProfile.contact.phoneDial,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": siteProfile.contact.address.street,
    "addressLocality": siteProfile.contact.address.city,
    "addressRegion": siteProfile.contact.address.state,
    "postalCode": siteProfile.contact.address.zip,
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": siteProfile.contact.coordinates.lat,
    "longitude": siteProfile.contact.coordinates.lng
  },
  "servesCuisine": siteProfile.schema.servesCuisine,
  "priceRange": siteProfile.schema.priceRange,
  "hasMap": siteProfile.contact.googleMapsUrl,
  "openingHoursSpecification": openingHoursSpecification,
  "sameAs": [
    siteProfile.social.instagram,
    siteProfile.social.facebook
  ].filter(Boolean)
};
---

<!-- Primary Meta -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:site_name" content={siteProfile.name} />
<meta property="og:locale" content="en_US" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Local Business Schema -->
<script type="application/ld+json" set:html={JSON.stringify(baseSchema)} />
