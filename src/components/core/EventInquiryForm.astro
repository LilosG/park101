---
import siteProfile from '../../data/site-profile.json';

interface Props {
  id?: string;
  eyebrow?: string;
  heading?: string;
  subtext?: string;
}

const {
  id = 'inquiry',
  eyebrow = 'Start Planning',
  heading = 'Request Your Date',
  subtext = 'Send us your date and headcount — our events team responds within 24 hours with availability and a custom plan.',
} = Astro.props;
---

<section id={id} class="relative bg-brand-cream py-20 px-6 sm:px-8 lg:px-12 scroll-mt-24">
  <div class="max-w-2xl mx-auto text-center mb-10">
    <span class="block font-body text-xs font-bold tracking-label uppercase text-brand-orange mb-3">
      {eyebrow}
    </span>
    <h2 class="font-display font-bold text-4xl sm:text-5xl text-brand-dark uppercase leading-display tracking-tight mb-4">
      {heading}
    </h2>
    <div class="w-12 h-[2px] bg-brand-orange mx-auto mb-5"></div>
    <p class="font-body font-light text-brand-dark/70 text-base sm:text-lg leading-relaxed">
      {subtext}
    </p>
  </div>

  <div class="max-w-2xl mx-auto bg-brand-white border border-brand-dark/10 rounded-lg shadow-sm overflow-hidden">
    <div class="py-16 px-8 flex flex-col items-center text-center bg-brand-cream-dark/40">
      <a
        href={siteProfile.ordering.inquiryFormUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-8 py-4 bg-brand-orange hover:bg-brand-orange-dark text-brand-white font-display font-bold uppercase tracking-button text-sm transition-colors duration-200"
      >
        Send Your Event Details
      </a>
    </div>
  </div>

  <p class="max-w-2xl mx-auto text-center font-body text-xs text-brand-dark/50 mt-4">
    Prefer to talk it through? Call{' '}
    <a href={`tel:${siteProfile.contact.phoneDial}`} class="text-brand-orange hover:text-brand-orange-dark underline underline-offset-2">
      {siteProfile.contact.phone}
    </a>.
  </p>
</section>
