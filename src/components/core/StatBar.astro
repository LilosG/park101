---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
}

const { stats } = Astro.props;
---

<section class="bg-brand-dark/95 border-t border-brand-white/10 py-8 px-6 sm:px-8 lg:px-12">
  <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-y-6 gap-x-4 md:divide-x divide-brand-white/10 text-center">
    {stats.map((stat) => (
      <div class="px-4">
        <span class="block font-display font-bold text-2xl text-brand-white uppercase tracking-wide">{stat.value}</span>
        <span class="block font-body text-xs tracking-stat uppercase text-brand-orange mt-1">{stat.label}</span>
      </div>
    ))}
  </div>
</section>
