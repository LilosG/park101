---
import { getCategoryMeta } from '../../data/blog-categories';

interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description: string;
      publishDate: Date;
      image?: string;
      imageAlt?: string;
      category: string;
    };
  };
}

const { post } = Astro.props;
const category = getCategoryMeta(post.data.category);
const formattedDate = post.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={`/blog/${post.id}`}
  class="group flex flex-col bg-brand-white rounded-lg overflow-hidden border border-brand-dark/10 hover:border-brand-orange/40 transition-colors duration-200"
>
  <div class="relative aspect-[4/3] overflow-hidden bg-brand-steel">
    {post.data.image && (
      <img
        src={post.data.image}
        alt={post.data.imageAlt ?? post.data.title}
        class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-105"
        loading="lazy"
      />
    )}
    <span class="absolute top-3 left-3 bg-brand-orange text-brand-white font-body text-xs font-bold uppercase tracking-label px-3 py-1 rounded-full">
      {category.label}
    </span>
  </div>
  <div class="flex flex-col flex-1 p-6">
    <time datetime={post.data.publishDate.toISOString()} class="font-body text-xs text-brand-dark/50 uppercase tracking-label mb-2">
      {formattedDate}
    </time>
    <h3 class="font-display font-bold text-xl text-brand-steel leading-tight mb-2 group-hover:text-brand-orange transition-colors duration-150">
      {post.data.title}
    </h3>
    <p class="font-body text-sm text-brand-dark/70 leading-relaxed line-clamp-3">
      {post.data.description}
    </p>
  </div>
</a>
