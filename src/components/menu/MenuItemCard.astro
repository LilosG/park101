---
interface Props {
  src: string;
  alt: string;
  name: string;
  description: string;
}

const { src, alt, name, description } = Astro.props;
---

<div class="group bg-brand-white overflow-hidden">
  <div class="relative aspect-square overflow-hidden">
    <img
      src={src}
      alt={alt}
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="p-4">
    <h3 class="font-display font-bold text-sm uppercase tracking-wide text-brand-dark mb-1">
      {name}
    </h3>
    <p class="font-body text-xs text-brand-dark/60 leading-relaxed">
      {description}
    </p>
  </div>
</div>
